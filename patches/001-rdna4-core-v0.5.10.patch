+def _should_replicate_deltanet_for_tp(
+    quant_config: Optional[QuantizationConfig],
+) -> bool:
+    """Whether to replicate DeltaNet+MLP layers across TP ranks.
+
+    FP8 models are too large to replicate everything, so only DeltaNet
+    projections are replicated while MLPs use standard TP splitting.
+    AWQ and unquantized models replicate both DeltaNet and MLP layers.
