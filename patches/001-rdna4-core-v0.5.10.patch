+        accumulator += tl.sum(a[:, None] * b, axis=0).to(accumulator_dtype)
+
+        offsets_k += BLOCK_SIZE_K * SPLIT_K
+        a_ptrs += BLOCK_SIZE_K * SPLIT_K
+        b_ptrs += BLOCK_SIZE_K * SPLIT_K * (N // 8)
+
+    # Store
+    c_ptrs = c_ptr + pid_z * N + offsets_sn
+    tl.store(c_ptrs, accumulator.to(c_ptr.type.element_ty), mask=offsets_sn < N)
+
+
+def awq_gemv_triton(
+    input: torch.Tensor,
+    qweight: torch.Tensor,
+    scales: torch.Tensor,
+    qzeros: torch.Tensor,
+    split_k_iters: int = 16,
+    block_size_n: int = 64,
+    block_size_k: int = 64,
+) -> torch.Tensor:
+    """AWQ GEMV for M=1 decode. Avoids GEMM tile overhead."""
+    assert input.shape[0] == 1, "GEMV kernel requires M=1"
+    M, K = input.shape
+    N = qweight.shape[1] * 8
+    group_size = qweight.shape[0] // qzeros.shape[0]
+
+    grid = (triton.cdiv(N, block_size_n), split_k_iters)
+    result = torch.zeros((split_k_iters, N), dtype=scales.dtype, device=input.device)
+
+    awq_gemv_kernel[grid](
+        input, qweight, result, qzeros, scales,
+        N, K, group_size,
+        BLOCK_SIZE_N=block_size_n,
+        BLOCK_SIZE_K=block_size_k,
+        SPLIT_K=split_k_iters,
+    )
+    return result.sum(0).unsqueeze(0)  # [1, N]
+
