+        masks_k = offsets_k < K
+        a = tl.load(a_ptrs, mask=masks_k, other=0.0)  # [BLOCK_SIZE_K]
+        b = tl.load(b_ptrs, mask=masks_k[:, None] & masks_bn[None, :], other=0.0)
+
+        # Unpack INT4
+        b = tl.interleave(b, b)
+        b = tl.interleave(b, b)
+        b = tl.interleave(b, b)
+
+        # Dequantize
+        offsets_szk = (BLOCK_SIZE_K * SPLIT_K * k + pid_z * BLOCK_SIZE_K) // group_size + tl.arange(0, 1)
+        masks_zk = offsets_szk < K // group_size
+
+        zeros = tl.load(zeros_ptr + (N // 8) * offsets_szk[:, None] + offsets_bn[None, :],
+                        mask=masks_zk[:, None] & masks_bn[None, :], other=0.0)
+        zeros = tl.interleave(zeros, zeros)
+        zeros = tl.interleave(zeros, zeros)
+        zeros = tl.interleave(zeros, zeros)
+        zeros = tl.broadcast_to(zeros, (BLOCK_SIZE_K, BLOCK_SIZE_N))
+
+        scales = tl.load(scales_ptr + N * offsets_szk[:, None] + offsets_sn[None, :],
+                         mask=masks_zk[:, None] & masks_sn[None, :], other=0.0)
+        scales = tl.broadcast_to(scales, (BLOCK_SIZE_K, BLOCK_SIZE_N))
+
+        b = (b >> shifts) & 0xF
+        zeros = (zeros >> shifts) & 0xF
+        b = (b - zeros) * scales
+        b = b.to(a_ptr.type.element_ty)
+
