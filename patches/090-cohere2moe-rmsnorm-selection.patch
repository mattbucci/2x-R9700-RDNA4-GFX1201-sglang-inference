+def select_norm_impl(config: PretrainedConfig) -> nn.Module:
+    """Select the checkpoint's normalization semantics.
+
+    North-Mini-Code sets ``rms_norm_eps`` and was trained with RMSNorm. Older
+    Cohere2-MoE checkpoints omit it and retain centered LayerNorm.
+    """
+    rms_norm_eps = getattr(config, "rms_norm_eps", None)
+    if rms_norm_eps is not None:
+        return RMSNorm(config.hidden_size, eps=rms_norm_eps)
+    return Cohere2MoeLayerNorm(
+        config.hidden_size, eps=getattr(config, "layer_norm_eps", 1e-5)
+    )
+
