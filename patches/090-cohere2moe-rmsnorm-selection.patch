--- /dev/null
+++ b/test/registered/unit/models/test_cohere2_moe_norm.py
@@ -0,0 +1,54 @@
+import unittest
+from types import SimpleNamespace
+
+import torch
+
+from sglang.srt.layers.layernorm import RMSNorm
+from sglang.srt.models.cohere2_moe import (
+    Cohere2MoeLayerNorm,
+    select_norm_impl,
+)
+from sglang.test.ci.ci_register import register_cpu_ci
+
+register_cpu_ci(est_time=4, suite="base-a-test-cpu")
+
+
+class TestCohere2MoeNormSelection(unittest.TestCase):
+    def test_rms_norm_config_uses_rms_semantics_and_epsilon(self):
+        config = SimpleNamespace(
+            hidden_size=4,
+            layer_norm_eps=1e-5,
+            rms_norm_eps=1e-6,
+        )
+
+        norm = select_norm_impl(config)
+
+        self.assertIsInstance(norm, RMSNorm)
+        self.assertEqual(norm.variance_epsilon, config.rms_norm_eps)
+
+        hidden_states = torch.tensor([[1.0, 2.0, 4.0, 8.0]])
+        expected = hidden_states * torch.rsqrt(
+            hidden_states.pow(2).mean(dim=-1, keepdim=True) + config.rms_norm_eps
+        )
+        torch.testing.assert_close(
+            norm.forward_native(hidden_states), expected, rtol=1e-6, atol=1e-6
+        )
+
+    def test_legacy_config_keeps_centered_layer_norm(self):
+        config = SimpleNamespace(
+            hidden_size=4,
+            layer_norm_eps=2e-5,
+            rms_norm_eps=None,
+        )
+
+        norm = select_norm_impl(config)
+
+        self.assertIsInstance(norm, Cohere2MoeLayerNorm)
+        self.assertEqual(norm.variance_epsilon, config.layer_norm_eps)
+
+        hidden_states = torch.tensor([[1.0, 2.0, 4.0, 8.0]])
+        centered = hidden_states - hidden_states.mean(dim=-1, keepdim=True)
+        expected = centered * torch.rsqrt(
+            centered.pow(2).mean(dim=-1, keepdim=True) + config.layer_norm_eps
+        )
+        torch.testing.assert_close(norm(hidden_states), expected, rtol=1e-6, atol=1e-6)
+
+
+if __name__ == "__main__":
+    unittest.main()
