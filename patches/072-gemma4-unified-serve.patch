+# Registers the vendored gemma4_unified processor stack with transformers' Auto*
+# registries so AutoProcessor.from_pretrained(google/gemma-4-12B[-it]) builds the
+# full Gemma4UnifiedProcessor (tokenizer + image_processor + feature_extractor)
+# instead of falling back to a bare GemmaTokenizer (the wall hit before patch 046).
+# tx 5.6 lacks these classes; the config (Gemma4UnifiedConfig) is already vendored
+# + AutoConfig-registered (patch 044). Imported once from hf_transformers/common.py
+# right after the _CONFIG_REGISTRY loop so registration runs at startup. -MB
+import logging
+
+logger = logging.getLogger(__name__)
+
+
+def register_gemma4_unified_processors():
+    try:
+        from transformers import (
+            AutoFeatureExtractor,
+            AutoImageProcessor,
+            AutoProcessor,
+            AutoVideoProcessor,
+        )
+
+        from sglang.srt.configs.feature_extraction_gemma4_unified import (
+            Gemma4UnifiedAudioFeatureExtractor,
+        )
+        from sglang.srt.configs.gemma4_unified import Gemma4UnifiedConfig
+        from sglang.srt.configs.image_processing_gemma4_unified import (
+            Gemma4UnifiedImageProcessor,
+        )
+        from sglang.srt.configs.processing_gemma4_unified import (
+            Gemma4UnifiedProcessor,
+        )
+        from sglang.srt.configs.video_processing_gemma4_unified import (
+            Gemma4UnifiedVideoProcessor,
+        )
+
+        # The unified image processor is a TorchvisionBackend (fast-only).
+        AutoImageProcessor.register(
+            Gemma4UnifiedConfig,
+            fast_image_processor_class=Gemma4UnifiedImageProcessor,
+            exist_ok=True,
+        )
+        AutoFeatureExtractor.register(
+            Gemma4UnifiedConfig, Gemma4UnifiedAudioFeatureExtractor, exist_ok=True
+        )
+        AutoVideoProcessor.register(
+            Gemma4UnifiedConfig, Gemma4UnifiedVideoProcessor, exist_ok=True
+        )
+        AutoProcessor.register(
+            Gemma4UnifiedConfig, Gemma4UnifiedProcessor, exist_ok=True
+        )
+    except Exception as e:  # never let this break startup for other models
+        logger.warning("gemma4_unified processor registration skipped: %s", e)
