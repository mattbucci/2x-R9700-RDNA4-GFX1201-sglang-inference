diff --git a/test/registered/jit/test_rdna4_standard_rmsnorm.py b/test/registered/jit/test_rdna4_standard_rmsnorm.py
new file mode 100644
--- /dev/null
+++ b/test/registered/jit/test_rdna4_standard_rmsnorm.py
@@ -0,0 +1,98 @@
+# SPDX-License-Identifier: Apache-2.0
+"""ROCm reference tests for the standard RMSNorm fusion paths."""
+
+import unittest
+
+import torch
+
+from sglang.jit_kernel.minimax_m3.rmsnorm import fused_add_rmsnorm, rmsnorm
+from sglang.srt.models.utils import fused_qk_rmsnorm
+from sglang.srt.utils import is_hip
+from sglang.test.ci.ci_register import register_amd_ci
+
+register_amd_ci(est_time=10, stage="jit-kernel-unit", runner_config="amd")
+
+EPS = 1e-6
+
+
+def _reference(x: torch.Tensor, weight: torch.Tensor) -> torch.Tensor:
+    xf = x.float()
+    return (
+        xf * torch.rsqrt(xf.square().mean(dim=-1, keepdim=True) + EPS)
+        * weight.float()
+    ).to(x.dtype)
+
+
+@unittest.skipUnless(is_hip() and torch.cuda.is_available(), "ROCm GPU required")
+class TestRDNA4StandardRMSNorm(unittest.TestCase):
+    def test_plain_and_fused_add_match_reference(self):
+        for rows, hidden in ((1, 128), (8, 2048), (64, 2048)):
+            with self.subTest(rows=rows, hidden=hidden):
+                x = torch.randn(rows, hidden, dtype=torch.bfloat16, device="cuda")
+                residual = torch.randn_like(x)
+                weight = torch.randn(hidden, dtype=torch.bfloat16, device="cuda")
+
+                torch.testing.assert_close(
+                    rmsnorm(x, weight, EPS),
+                    _reference(x, weight),
+                    rtol=0.008,
+                    atol=0.0078125,
+                )
+                out, residual_out = fused_add_rmsnorm(x, residual, weight, EPS)
+                summed = x.float() + residual.float()
+                expected_residual = summed.to(x.dtype)
+                torch.testing.assert_close(
+                    residual_out, expected_residual, rtol=0, atol=0
+                )
+                torch.testing.assert_close(
+                    out,
+                    (
+                        summed
+                        * torch.rsqrt(
+                            summed.square().mean(dim=-1, keepdim=True) + EPS
+                        )
+                        * weight.float()
+                    ).to(x.dtype),
+                    rtol=0.008,
+                    atol=0.0078125,
+                )
+
+    def test_qk_fusion_reads_strided_prefill_views_without_copy(self):
+        for tokens, query_heads in ((1, 24), (8, 32), (64, 24)):
+            with self.subTest(tokens=tokens, query_heads=query_heads):
+                kv_heads, head_dim = 4, 128
+                packed_width = (query_heads + 2 * kv_heads) * head_dim
+                packed = torch.randn(
+                    tokens,
+                    packed_width,
+                    dtype=torch.bfloat16,
+                    device="cuda",
+                )
+                q, k, _ = packed.split(
+                    [query_heads * head_dim, kv_heads * head_dim, kv_heads * head_dim],
+                    dim=-1,
+                )
+                q_weight = torch.randn(
+                    head_dim, dtype=torch.bfloat16, device="cuda"
+                )
+                k_weight = torch.randn_like(q_weight)
+
+                q_out, k_out = fused_qk_rmsnorm(
+                    q, k, q_weight, k_weight, EPS, head_dim
+                )
+                torch.testing.assert_close(
+                    q_out,
+                    _reference(q.reshape(-1, head_dim), q_weight),
+                    rtol=0.008,
+                    atol=0.0078125,
+                )
+                torch.testing.assert_close(
+                    k_out,
+                    _reference(k.reshape(-1, head_dim), k_weight),
+                    rtol=0.008,
+                    atol=0.0078125,
+                )
+
+
+if __name__ == "__main__":
+    unittest.main()
