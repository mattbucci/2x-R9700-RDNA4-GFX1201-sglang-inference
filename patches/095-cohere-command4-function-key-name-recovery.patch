+class TestCohereCommand4FunctionKeyRecovery(unittest.TestCase):
+    """The second malformed North variant: the name arrives under a string
+    ``function`` key with no ``name``/``tool_name``/``tool_call_id`` field.
+    Observed at 64801 rendered tokens in the post-094 profile A/B, where a
+    semantically correct action was dropped and its raw markup leaked into
+    ``content`` with ``finish_reason == "stop"``.
+    """
+
+    def setUp(self):
+        self.tools = [
+            Tool(
+                function=Function(
+                    name=name,
+                    parameters={"type": "object", "properties": {}},
+                )
+            )
+            for name in ("lookup_record", "get_weather", "search")
+        ]
+        self.detector = CohereCommand4Detector()
+
+    def _parse(self, action):
+        text = (
+            self.detector.bot_token
+            + json.dumps([action], separators=(",", ":"))
+            + self.detector.eot_token
+        )
+        with envs.SGLANG_FORWARD_UNKNOWN_TOOLS.override(False):
+            return self.detector.detect_and_parse(text, self.tools).calls
+
+    def test_recovers_exact_exposed_name_from_string_function(self):
+        calls = self._parse(
+            {"function": "lookup_record", "parameters": {"id": "BANANA42"}}
+        )
+
+        self.assertEqual(len(calls), 1)
+        self.assertEqual(calls[0].name, "lookup_record")
+        self.assertEqual(calls[0].tool_index, 0)
+        self.assertEqual(json.loads(calls[0].parameters), {"id": "BANANA42"})
+
+    def test_verbatim_depth_regression_payload(self):
+        # Byte-for-byte the content the server dropped in
+        # north-mini-tooluse-profile-ab-post094-2026-07-19.json (seed 1).
+        text = (
+            '<|START_ACTION|>[\n    {"function": "lookup_record", '
+            '"parameters": {"id": "BANANA42"}}\n]<|END_ACTION|>'
+        )
+        with envs.SGLANG_FORWARD_UNKNOWN_TOOLS.override(False):
+            result = self.detector.detect_and_parse(text, self.tools)
+
+        self.assertEqual(len(result.calls), 1)
+        self.assertEqual(result.calls[0].name, "lookup_record")
+        self.assertEqual(
+            json.loads(result.calls[0].parameters), {"id": "BANANA42"}
+        )
+        self.assertEqual(result.normal_text, "")
+
+    def test_recovered_function_key_does_not_leak_into_parameters(self):
+        calls = self._parse(
+            {"function": "search", "parameters": {"query": "RDNA4"}}
+        )
+
+        self.assertEqual(len(calls), 1)
+        self.assertNotIn("function", json.loads(calls[0].parameters))
+
+    def test_unknown_or_inexact_function_strings_are_rejected(self):
+        for function in (
+            "unknown",
+            " lookup_record ",
+            "LOOKUP_RECORD",
+            "functions.lookup_record",
+            "lookup_record:0",
+            "",
+        ):
+            with self.subTest(function=function):
+                self.assertEqual(
+                    self._parse({"function": function, "parameters": {}}), []
+                )
+
+    def test_non_string_function_values_are_not_names(self):
+        # The OpenAI nested object is a different shape and must not be
+        # coerced; neither may a list or a bare null.
+        for function in (
+            {"name": "lookup_record", "arguments": "{}"},
+            ["lookup_record"],
+            None,
+            0,
+        ):
+            with self.subTest(function=function):
+                self.assertEqual(
+                    self._parse({"function": function, "parameters": {}}), []
+                )
+
+    def test_explicit_name_fields_win_over_function(self):
+        for action, expected in (
+            (
+                {
+                    "name": "search",
+                    "function": "lookup_record",
+                    "parameters": {},
+                },
+                "search",
+            ),
+            (
+                {
+                    "tool_name": "search",
+                    "function": "lookup_record",
+                    "parameters": {},
+                },
+                "search",
+            ),
+        ):
+            with self.subTest(action=action):
+                calls = self._parse(action)
+                self.assertEqual(len(calls), 1)
+                self.assertEqual(calls[0].name, expected)
+
+    def test_tool_call_id_recovery_still_wins_over_function(self):
+        calls = self._parse(
+            {
+                "tool_call_id": "search",
+                "function": "lookup_record",
+                "parameters": {},
+            }
+        )
+
+        self.assertEqual(len(calls), 1)
+        self.assertEqual(calls[0].name, "search")
+
+    def test_streaming_uses_the_same_recovery(self):
+        first = self.detector.parse_streaming_increment(
+            "prefix" + self.detector.bot_token, self.tools
+        )
+        with envs.SGLANG_FORWARD_UNKNOWN_TOOLS.override(False):
+            second = self.detector.parse_streaming_increment(
+                json.dumps(
+                    [{"function": "search", "parameters": {"query": "gfx1201"}}],
+                    separators=(",", ":"),
+                )
+                + self.detector.eot_token,
+                self.tools,
+            )
+
+        self.assertEqual(first.normal_text, "prefix")
+        self.assertEqual(len(second.calls), 1)
+        self.assertEqual(second.calls[0].name, "search")
+
+
 if __name__ == "__main__":
     unittest.main()
