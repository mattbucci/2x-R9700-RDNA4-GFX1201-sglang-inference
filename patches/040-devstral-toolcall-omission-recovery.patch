+    def _trailing_known_tool_name_len(self, buffer: str) -> int:
+        """Length of a trailing run that exactly equals a known tool name.
+
+        Used by streaming [TOOL_CALLS]-omission recovery: when the buffer ends
+        with a bare known tool name (e.g. ``…\\n\\ntask``), it may be the name of
+        a call whose [TOOL_CALLS] marker was dropped and whose [ARGS] token has
+        not streamed in yet, so it is held back rather than flushed as content.
+        Returns 0 when the trailing identifier is not an exact tool name (so
+        ordinary prose — including words that merely contain a tool name — is
+        flushed normally and never truncated).
+        """
+        if not getattr(self, "_tool_indices", None):
+            return 0
+        k = len(buffer)
+        while k > 0 and (buffer[k - 1].isalnum() or buffer[k - 1] in "_.-"):
+            k -= 1
+        trailing = buffer[k:]
+        return len(trailing) if trailing and trailing in self._tool_indices else 0
