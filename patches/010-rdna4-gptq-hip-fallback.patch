+    @staticmethod
+    def _hip_gptq_dequant_matmul(
+        x: torch.Tensor,
+        qweight: torch.Tensor,
+        qzeros: torch.Tensor,
+        scales: torch.Tensor,
+        g_idx: torch.Tensor,
+        bits: int,
+    ) -> torch.Tensor:
+        """Torch-based GPTQ dequant+matmul for HIP/ROCm."""
+        pack_factor = 32 // bits
+        # qweight: [K//pack, N] int32, GPTQ sequential packing
+        K = qweight.shape[0] * pack_factor
+        N = qweight.shape[1]
+
+        # Unpack int32 → 4-bit values
+        # qweight is [K//pack, N] with pack along K dim
+        unpacked = []
+        for i in range(pack_factor):
+            unpacked.append((qweight >> (i * bits)) & ((1 << bits) - 1))
+        # Stack along dim=1 (between K/pack and N) to get [K/pack, pack, N]
+        # then reshape to [K, N] so K indices are contiguous
+        w_int = torch.stack(unpacked, dim=1).reshape(K, N)  # [K, N]
+
+        # Apply g_idx reordering if present
+        if g_idx.numel() > 0 and g_idx.numel() == K:
+            group_indices = g_idx
+        else:
+            group_size = K // scales.shape[0] if scales.shape[0] > 0 else K
+            group_indices = torch.arange(K, device=qweight.device) // group_size
+
+        # Dequantize: (w_int - zp) * scale
+        # qzeros: [groups, N//pack] int32
+        zp_unpacked = []
+        for i in range(pack_factor):
+            zp_unpacked.append((qzeros >> (i * bits)) & ((1 << bits) - 1))
+        zp_all = torch.stack(zp_unpacked, dim=-1).reshape(qzeros.shape[0], -1)  # [groups, N]
+        if zp_all.shape[1] > N:
+            zp_all = zp_all[:, :N]
+
+        # Expand per group
+        zp = zp_all[group_indices]  # [K, N]
+        sc = scales[group_indices]  # [K, N]
+
+        # GPTQ v1 format: actual_zp = stored_zp + 1
+        w_float = (w_int.to(torch.float32) - (zp.to(torch.float32) + 1.0)) * sc.to(torch.float32)
+
+        # Matmul in FP32 to avoid BF16 precision loss through 60 layers
+        return torch.matmul(x.to(torch.float32), w_float).to(x.dtype)
+
