         self.req_to_token_pool = model_runner.req_to_token_pool
@@ -356,6 +364,47 @@ class TritonAttnBackend(AttentionBackend):
         )
         return kv_indptr
 
+    def _build_windowed_verify_indices(
+        self,
+        bs: int,
+        seq_lens: torch.Tensor,
+        req_pool_indices: torch.Tensor,
+        window: int,
+        sink: int,
+    ):
+        """R9700 #38 partial-verification: build (kv_indptr, kv_indices) keeping only the last
+        ``window - sink`` tokens + the first ``sink`` sink tokens of each request's prefix, for the
+        spec verify. The verify prefix attention is mask-free (skip_prefix_custom_mask), so the
+        verify reads only this windowed set instead of the full deep KV. Per-request gather (bs is
+        small for single-user verify); eager only (.tolist() syncs) — not for cuda-graph capture."""
+        seq_lens_cpu = seq_lens.tolist()
+        rpi = req_pool_indices.tolist()
+        recent = max(int(window) - int(sink), 1)
+        chunks = []
+        lens = []
+        for b in range(bs):
+            L = int(seq_lens_cpu[b])
+            rb = int(rpi[b])
+            if L <= int(window):
+                sel = self.req_to_token[rb, :L]
+            else:
+                s = min(int(sink), L)
+                r = min(recent, L - s)
+                if s > 0:
+                    sel = torch.cat(
+                        [self.req_to_token[rb, :s], self.req_to_token[rb, L - r : L]]
+                    )
+                else:
+                    sel = self.req_to_token[rb, L - r : L]
+            chunks.append(sel)
+            lens.append(sel.numel())
+        kv_indices = torch.cat(chunks).to(torch.int64)
+        kv_indptr = torch.zeros(bs + 1, dtype=torch.int32, device=self.device)
+        kv_indptr[1:] = torch.cumsum(
+            torch.tensor(lens, dtype=torch.int32, device=self.device), dim=0
+        )
+        return kv_indptr, kv_indices
+
     def _update_decode_kv_buffers(
         self,
         bs: int,
@@ -690,6 +739,20 @@ class TritonAttnBackend(AttentionBackend):
                 kv_indices,
             )
 
+            # R9700 #38 partial-verification (eager path; cuda-graph verify untouched → use with
+            # --disable-cuda-graph). Replace the full verify prefix indices with a windowed set
+            # (last N + first S sink). The verify prefix is mask-free (skip_prefix_custom_mask), so
+            # this is safe arithmetically; the suffix tree-mask must stay consistent under the
+            # shrunk prefix — SMOKE-VALIDATE (temp=0 coherence) before trusting. Default off.
+            if self.force_verify_window is not None and self.force_verify_window > 0:
+                kv_indptr, kv_indices = self._build_windowed_verify_indices(
+                    bs,
+                    forward_batch.seq_lens,
+                    forward_batch.req_pool_indices,
+                    self.force_verify_window,
+                    self.verify_sink,
+                )
+
