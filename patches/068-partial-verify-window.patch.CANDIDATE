+        # (skip_prefix_custom_mask), so feeding the verify a windowed kv_indptr/kv_indices is
+        # clean. Default -1 (off) → verify reads the full prefix as before. LOSSY spec.
+        self.force_verify_window = (
+            getattr(model_runner.server_args, "force_verify_window", -1) or -1
+        )
+        self.verify_sink = getattr(model_runner.server_args, "verify_sink", 0) or 0
         # Pool refs — captured at construction so they survive deletion of the
