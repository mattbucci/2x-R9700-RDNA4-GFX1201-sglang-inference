+        # R9700 #35: --force-decode-window decode-only mode. When >0, the prefill
+        # (extend) path keeps FULL attention (so the model builds a coherent full-
+        # context representation), and only the DECODE path windows. Gated on this
+        # flag (default -1) so native-SWA models (Gemma) are unaffected.
+        self.force_decode_window = (
+            getattr(model_runner.server_args, "force_decode_window", -1) or -1
+        )
+        # R9700 #38: --force-verify-window N (+ --verify-sink S) windows the spec-VERIFY's
+        # prefix KV read (last N + first S sink tokens). The verify prefix is mask-free
+        # (skip_prefix_custom_mask), so feeding the verify a windowed kv_indptr/kv_indices is
+        # clean. Default -1 (off) → verify reads the full prefix as before. LOSSY spec.
+        self.force_verify_window = (
+            getattr(model_runner.server_args, "force_verify_window", -1) or -1
+        )
+        self.verify_sink = getattr(model_runner.server_args, "verify_sink", 0) or 0
         # Pool refs — captured at construction so they survive deletion of the
         # corresponding ForwardBatch fields.
         self.req_to_token_pool = model_runner.req_to_token_pool
@@ -349,6 +364,47 @@ class TritonAttnBackend(AttentionBackend):
         )
         return kv_indptr
 
+    def _build_windowed_verify_indices(
+        self,
+        bs: int,
+        seq_lens: torch.Tensor,
+        req_pool_indices: torch.Tensor,
+        window: int,
+        sink: int,
+    ):
+        """R9700 #38 partial-verification: build (kv_indptr, kv_indices) keeping only the last
+        ``window - sink`` tokens + the first ``sink`` sink tokens of each request's prefix, for the
+        spec verify. The verify prefix attention is mask-free (skip_prefix_custom_mask), so the
+        verify reads only this windowed set instead of the full deep KV. Per-request gather (bs is
+        small for single-user verify); eager only (.tolist() syncs) — not for cuda-graph capture."""
+        seq_lens_cpu = seq_lens.tolist()
+        rpi = req_pool_indices.tolist()
+        recent = max(int(window) - int(sink), 1)
+        chunks = []
+        lens = []
+        for b in range(bs):
+            L = int(seq_lens_cpu[b])
+            rb = int(rpi[b])
+            if L <= int(window):
+                sel = self.req_to_token[rb, :L]
+            else:
+                s = min(int(sink), L)
+                r = min(recent, L - s)
+                if s > 0:
+                    sel = torch.cat(
+                        [self.req_to_token[rb, :s], self.req_to_token[rb, L - r : L]]
+                    )
+                else:
+                    sel = self.req_to_token[rb, L - r : L]
+            chunks.append(sel)
+            lens.append(sel.numel())
+        kv_indices = torch.cat(chunks).to(torch.int64)
+        kv_indptr = torch.zeros(bs + 1, dtype=torch.int32, device=self.device)
+        kv_indptr[1:] = torch.cumsum(
+            torch.tensor(lens, dtype=torch.int32, device=self.device), dim=0
+        )
+        return kv_indptr, kv_indices
+
     def _update_decode_kv_buffers(
         self,
         bs: int,
@@ -683,6 +739,20 @@ class TritonAttnBackend(AttentionBackend):
                 kv_indices,
             )
 
+            # R9700 #38 partial-verification (eager path; cuda-graph verify untouched → use with
+            # --disable-cuda-graph). Replace the full verify prefix indices with a windowed set
+            # (last N + first S sink). The verify prefix is mask-free (skip_prefix_custom_mask), so
+            # this is safe arithmetically; the suffix tree-mask must stay consistent under the
+            # shrunk prefix — SMOKE-VALIDATE (temp=0 coherence) before trusting. Default off.
+            if self.force_verify_window is not None and self.force_verify_window > 0:
+                kv_indptr, kv_indices = self._build_windowed_verify_indices(
+                    bs,
+                    forward_batch.seq_lens,
+                    forward_batch.req_pool_indices,
+                    self.force_verify_window,
+                    self.verify_sink,
+                )
+
             if self.sliding_window_size is not None and self.sliding_window_size > 0:
                 # window_kv_offsets is used to calculate the start position in custom mask
                 (
@@ -1148,8 +1218,16 @@ class TritonAttnBackend(AttentionBackend):
                 q, o, layer, forward_batch, causal, logits_soft_cap, sinks
             )
 
-        # Normal mode: use original 2-stage kernel
-        if layer.sliding_window_size is not None and layer.sliding_window_size > -1:
+        # Normal mode: use original 2-stage kernel.
+        # R9700 #35 decode-only: when force_decode_window>0, the EXTEND (prefill) path
+        # stays FULL even on windowed layers — only DECODE windows (forward_decode is
+        # unchanged). Native-SWA models have force_decode_window=-1 → window as before.
+        _decode_only_full_prefill = self.force_decode_window is not None and self.force_decode_window > 0
+        if (
+            layer.sliding_window_size is not None
+            and layer.sliding_window_size > -1
+            and not _decode_only_full_prefill
+        ):
             sliding_window_size = (
                 layer.sliding_window_size
