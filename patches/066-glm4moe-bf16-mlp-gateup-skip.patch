+def _mlp_quant_config(quant_config, mlp_prefix):
+    """Return None (BF16) when this MLP's gate/up/down are in modules_to_not_convert.
+
+    Glm4MoeMLP MERGES gate+up into a single ``gate_up_proj`` Linear, but the quant config's
+    ``modules_to_not_convert`` lists ``gate_proj``/``up_proj`` SEPARATELY. The skip-check is a
+    substring match, and ``"...mlp.gate_proj"`` is NOT a substring of ``"...mlp.gate_up_proj"``
+    (it's gate_UP_proj), so the merged Linear misses the skip and is built quantized while the
+    checkpoint weights are BF16 -> the weights don't bind -> NaN logits (RDNA4 2026-06-17,
+    glm45-air layer-0 dense MLP + every layer's shared_experts; `down_proj` matched fine). When the
+    MLP is BF16 (gate_proj in the ignore list) pass quant_config=None so the whole MLP — including
+    the merged gate_up_proj — loads unquantized. Fleet-safe: a quantized MLP (gate_proj not in the
+    list) is unchanged.
+    """
+    mtnc = getattr(quant_config, "modules_to_not_convert", None) or []
+    if f"{mlp_prefix}.gate_proj" in mtnc:
+        return None
+    return quant_config
+
