+def _rdna4_torch_moe(
+    A: torch.Tensor,  # [num_tokens, K] fp8
+    B: torch.Tensor,  # [E, N, K] fp8
+    C: torch.Tensor,  # output
+    A_scale: Optional[torch.Tensor],
+    B_scale: Optional[torch.Tensor],
+    topk_weights: torch.Tensor,
+    topk_ids: torch.Tensor,
+    sorted_token_ids: torch.Tensor,
+    expert_ids: torch.Tensor,
+    num_tokens_post_padded: torch.Tensor,
+    mul_routed_weight: bool,
+    top_k: int,
+    block_shape: Optional[List[int]],
+    per_channel_quant: bool,
+    compute_type,
+) -> None:
+    """Torch-native FP8 MoE for RDNA4: dequantize weights to BF16, per-expert matmul.
+    A is BF16 (we skip FP8 activation quant), B is FP8 (model weights)."""
+    out_dtype = torch.bfloat16 if compute_type == tl.bfloat16 else torch.float16
+    E, N, K = B.shape
+    num_valid = topk_ids.numel()
+
+    # Sync to catch async errors from prior kernels
+    torch.cuda.synchronize()
+
+    # A is already BF16 (we skip FP8 quant for RDNA4)
+    A_bf16 = A.to(out_dtype) if A.dtype != out_dtype else A
+
+    # Process each expert that has tokens assigned
+    C.zero_()
+    num_experts_used = expert_ids.shape[0]
+    block_m = 16  # matches BLOCK_SIZE_M from config
+
+    for block_idx in range(num_experts_used):
+        expert_id = expert_ids[block_idx].item()
+        if expert_id == -1:
+            continue
+
+        # Get token indices for this block
+        start = block_idx * block_m
+        end = min(start + block_m, sorted_token_ids.shape[0])
+        token_ids = sorted_token_ids[start:end]
+
+        # Filter valid tokens
+        valid_mask = token_ids < num_valid
+        if not valid_mask.any():
+            continue
+
+        valid_token_ids = token_ids[valid_mask]
+        # Map to actual input token index (divide by top_k)
+        input_ids = valid_token_ids // top_k
+
+        # Gather input tokens
+        a_tokens = A_bf16[input_ids]  # [num_valid_in_block, K]
+
+        # Dequantize B for this expert
+        b_expert = B[expert_id].to(out_dtype)  # [N, K]
+
+        # Apply B scales for block-quantized
+        if block_shape is not None and B_scale is not None:
+            block_n, block_k = block_shape
+            # B_scale: [E, N//block_n, K//block_k]
+            bs = B_scale[expert_id]  # [N//block_n, K//block_k]
+            bs_expanded = bs.repeat_interleave(block_n, dim=0).repeat_interleave(block_k, dim=1)
+            bs_expanded = bs_expanded[:N, :K]
+            b_expert = b_expert * bs_expanded.to(out_dtype)
+        elif B_scale is not None:
+            if B_scale.ndim == 1:
+                b_expert = b_expert * B_scale[expert_id].item()
+            elif per_channel_quant and B_scale.ndim >= 2:
+                b_expert = b_expert * B_scale[expert_id].to(out_dtype)
+
+        # Matmul: [num_valid, K] @ [K, N] -> [num_valid, N]
+        result = torch.mm(a_tokens, b_expert.t())  # b_expert is [N, K], transpose to [K, N]
+
+        # Apply routing weights
+        if mul_routed_weight:
+            weights = topk_weights.view(-1)[valid_token_ids]
+            result = result * weights.unsqueeze(-1)
+
+        # Scatter results back
+        result = result.to(out_dtype)
+        # C layout depends on whether it's the first or second GEMM
+        if C.ndim == 2:
+            C[valid_token_ids] += result
+        elif C.ndim == 3:
+            # For topk > 1, C is [M, topk, N] indexed by token position
+            C.view(-1, C.shape[-1])[valid_token_ids] += result
+
