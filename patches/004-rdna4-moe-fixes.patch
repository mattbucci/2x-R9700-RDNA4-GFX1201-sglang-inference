+        # Count tokens per expert (including -1 for filtered experts)
+        expert_counts = torch.zeros(num_experts + 2, dtype=torch.int32, device=topk_ids.device)
+        for e in range(num_experts):
+            expert_counts[e + 1] = (flat_ids == e).sum()
+        # Count -1 (filtered) tokens
+        expert_counts[0] = (flat_ids == -1).sum()
+
+        # Pad each expert's count to be divisible by block_size
+        padded_counts = ((expert_counts + block_size - 1) // block_size) * block_size
+
+        # Compute cumulative offsets
+        cumsum = torch.zeros_like(padded_counts)
+        torch.cumsum(padded_counts, dim=0, out=cumsum)
+        total_padded = cumsum[-1].item()
+
+        # Fill sorted_ids: for each expert, place its token indices, then padding
+        sorted_ids.fill_(num_tokens_total)  # padding value = num_tokens_total
+        expert_offsets = torch.zeros(num_experts + 2, dtype=torch.int32, device=topk_ids.device)
+        expert_offsets[1:] = cumsum[:-1]
+
+        for idx in range(num_tokens_total):
+            expert = flat_ids[idx].item()
+            if expert == -1:
+                pos = expert_offsets[0].item()
+                expert_offsets[0] += 1
+            else:
+                pos = expert_offsets[expert + 1].item()
+                expert_offsets[expert + 1] += 1
+            if pos < sorted_ids.shape[0]:
+                sorted_ids[pos] = idx
+
+        # Fill expert_ids: each block gets the expert index
+        block_idx = 0
+        for e in range(num_experts + 1):
+            n_blocks = padded_counts[e].item() // block_size
+            expert_val = e - 1  # -1 for filtered, 0..num_experts-1 for real experts
+            for _ in range(n_blocks):
+                if block_idx < expert_ids.shape[0]:
+                    expert_ids[block_idx] = expert_val
+                block_idx += 1
+
+        num_tokens_post_pad[0] = min(total_padded, sorted_ids.shape[0])
+
     return sorted_ids, expert_ids, num_tokens_post_pad
