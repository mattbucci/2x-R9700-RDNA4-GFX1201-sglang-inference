                 return MoeWNA16Config.from_config(config).get_quant_method(
                     layer, prefix
                 )
-            return GPTQMarlinMoEMethod(quant_args_marlin)
+            # use_marlin=False (RDNA4/ROCm has no marlin kernels): use the WNA16 MoE
