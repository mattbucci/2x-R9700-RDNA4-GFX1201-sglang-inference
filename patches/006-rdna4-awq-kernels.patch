+        py::arg("activation"), py::arg("qweight"), py::arg("scales"),
+        py::arg("qzeros"), py::arg("output"), py::arg("sorted_token_ids"),
+        py::arg("expert_ids"), py::arg("topk_weights"),
+        py::arg("top_k"), py::arg("mul_routed_weight"),
+        py::arg("split_k") = 0);
