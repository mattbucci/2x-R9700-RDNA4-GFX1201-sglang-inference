@@ -0,0 +1,77 @@
+import unittest
+from types import SimpleNamespace
+from unittest.mock import patch
+
+from torch import nn
+
+from sglang.srt.models.cohere2_moe import (
+    Cohere2MoeAttention,
+    Cohere2MoeForCausalLM,
+    get_attention_sliding_window_size,
+)
+from sglang.test.ci.ci_register import register_cpu_ci
+
+register_cpu_ci(est_time=4, suite="base-a-test-cpu")
+
+
+class _StubLinear(nn.Module):
+    def __init__(self, *args, **kwargs):
+        super().__init__()
+
+
+class _StubAttention(nn.Module):
+    def __init__(self, *args, sliding_window_size, **kwargs):
+        super().__init__()
+        self.sliding_window_size = sliding_window_size
+
+
+class TestCohere2MoeSlidingWindow(unittest.TestCase):
+    @staticmethod
+    def _config():
+        return SimpleNamespace(
+            hidden_size=16,
+            num_attention_heads=2,
+            num_key_value_heads=1,
+            head_dim=8,
+            max_position_embeddings=8192,
+            rope_theta=50000.0,
+            layer_types=["sliding_attention", "full_attention"],
+            first_k_dense_replace=0,
+            prefix_dense_sliding_window_pattern=1,
+            sliding_window=4096,
+        )
+
+    def test_hf_inclusive_window_is_converted_to_exclusive_distance(self):
+        config = self._config()
+
+        self.assertEqual(get_attention_sliding_window_size(config), 4095)
+        self.assertIsNone(get_attention_sliding_window_size(SimpleNamespace()))
+
+    def test_only_sliding_layers_receive_the_converted_window(self):
+        config = self._config()
+        module = "sglang.srt.models.cohere2_moe"
+        with (
+            patch(f"{module}.get_parallel", return_value=SimpleNamespace(tp_size=1)),
+            patch(f"{module}.QKVParallelLinear", _StubLinear),
+            patch(f"{module}.RowParallelLinear", _StubLinear),
+            patch(f"{module}.RadixAttention", _StubAttention),
+            patch(f"{module}.get_rope", return_value=nn.Identity()),
+        ):
+            sliding = Cohere2MoeAttention(config, layer_id=0)
+            full = Cohere2MoeAttention(config, layer_id=1)
+
+        self.assertEqual(sliding.sliding_window_size, 4095)
+        self.assertEqual(sliding.attn.sliding_window_size, 4095)
+        self.assertEqual(full.sliding_window_size, -1)
+        self.assertEqual(full.attn.sliding_window_size, -1)
+
+    def test_model_exposes_the_same_window_to_attention_backends(self):
+        model = Cohere2MoeForCausalLM.__new__(Cohere2MoeForCausalLM)
+        nn.Module.__init__(model)
+        model.config = self._config()
+
+        self.assertEqual(model.get_attention_sliding_window_size(), 4095)
+
+
+if __name__ == "__main__":
+    unittest.main()
