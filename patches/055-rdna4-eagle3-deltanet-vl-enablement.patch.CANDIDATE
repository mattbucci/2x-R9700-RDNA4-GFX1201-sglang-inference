diff --git a/python/sglang/srt/models/qwen3_vl.py b/python/sglang/srt/models/qwen3_vl.py
index 1b6c185..bd53b93 100644
--- a/python/sglang/srt/models/qwen3_vl.py
+++ b/python/sglang/srt/models/qwen3_vl.py
@@ -1400,13 +1400,23 @@ class Qwen3VLForConditionalGeneration(nn.Module):
         self.model.capture_aux_hidden_states = True
         if layer_ids is None:
             num_layers = self.config.num_hidden_layers
-            self.model.layers_to_capture = [
+            capture = [
                 2,
                 num_layers // 2,
                 num_layers - 3,
             ]  # Specific layers for EAGLE3 support
         else:
-            self.model.layers_to_capture = [val + 1 for val in layer_ids]
+            capture = [val + 1 for val in layer_ids]
+        # Route through the text model's capture setter so each layer module gets
+        # ``_is_layer_to_capture=True`` — the qwen3_5 DeltaNet backbone has no
+        # dedicated EAGLE3 setter (only DFLASH), and the forward at
+        # ``qwen3_5.py`` appends a layer's output to ``aux_hidden_states`` ONLY
+        # when that flag is set.  Assigning ``self.model.layers_to_capture``
+        # alone (the old code) left the flag unset, so nothing was captured and
+        # the bare-tensor return tripped ``hidden_states, aux = hidden_states``
+        # ("too many values to unpack").  The marking mechanism is shared
+        # between DFLASH and EAGLE3 capture.
+        self.model.set_dflash_layers_to_capture(capture)
 
 
 EntryClass = Qwen3VLForConditionalGeneration
