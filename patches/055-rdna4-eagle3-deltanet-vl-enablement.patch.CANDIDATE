         PretrainedConfig.standardize_rope_params = _safe_standardize
 
 
+def _patch_llama_head_dim_validation():
+    """Allow decoupled-head-dim LlamaConfig (explicit head_dim, so hidden_size
+    need NOT be divisible by num_attention_heads).
+
+    transformers v5 ``LlamaConfig`` is ``@strict`` and its
+    ``validate_architecture`` unconditionally requires
+    ``hidden_size % num_attention_heads == 0`` — even when ``head_dim`` is set
+    independently.  Modern EAGLE3 / speculative drafts use a decoupled head_dim
+    (e.g. hidden 5120, 24 heads, head_dim 256 -> q_proj 6144 != hidden), which
+    is a *valid* geometry but is rejected at config-load with
+    "The hidden size (5120) is not a multiple of the number of attention heads
+    (24)".  The check is not load-bearing (the model uses ``head_dim``, not
+    ``hidden_size // num_attention_heads``), and conventional models pass it
+    trivially, so dropping it is monotonic: it only *admits* previously-rejected
+    decoupled drafts and changes nothing for configs that already passed.
+
+    ``@strict`` snapshots class validators into ``cls.__class_validators__`` at
+    decoration time and ``validate()`` iterates that list, so we must edit the
+    list directly — re-binding the ``validate_architecture`` attribute would
+    have no effect.
+
+    TODO(upstream): ``LlamaConfig.validate_architecture`` should skip the
+    divisibility check whenever ``head_dim`` is explicitly provided.
+    """
+    try:
+        from transformers.models.llama.configuration_llama import LlamaConfig
+    except ImportError:
+        return
+    validators = getattr(LlamaConfig, "__class_validators__", None)
+    if not validators:
+        return
+    kept = [
+        v for v in validators if getattr(v, "__name__", "") != "validate_architecture"
+    ]
+    if len(kept) != len(validators):
+        LlamaConfig.__class_validators__ = kept
+
+
 def _patch_flash_attn_availability():
     """Prevent flash-attn-4 from masquerading as flash-attn-2.
 
