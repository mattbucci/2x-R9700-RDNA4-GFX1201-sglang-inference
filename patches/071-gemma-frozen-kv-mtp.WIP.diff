+        # R9700 #36: the fb-view registry (cuda_graph_buffer_registry.fill_from, used by BOTH the
+        # eager _eager_fb_view and the cuda-graph replay paths) copies out_cache_loc into a
+        # decode-sized buffer. The FROZEN_KV draft inherits the target PREFILL's out_cache_loc
+        # (size = prefill seq len, e.g. 35) which mismatches the draft decode token count (bs*topk)
+        # -> "output with shape [N] doesn't match the broadcast shape [prefill_len]". The draft's
+        # attention layers are kv-shared (read the FROZEN target KV at the fixed seq_len-1 rope
+        # position, no new KV writes), so out_cache_loc is unused for writing — resize it to the
+        # draft decode token count (reusing valid existing slot ids) so the registry copy matches.
+        _n_tok = forward_batch.positions.numel()
+        _oc = forward_batch.out_cache_loc
+        if _oc is not None and _oc.numel() != _n_tok:
+            forward_batch.out_cache_loc = (
+                _oc[:_n_tok].contiguous()
+                if _oc.numel() >= _n_tok
+                else _oc[:1].repeat(_n_tok)
+            )
+
         can_run_cuda_graph = self.cuda_graph_runner and self.cuda_graph_runner.can_run(
