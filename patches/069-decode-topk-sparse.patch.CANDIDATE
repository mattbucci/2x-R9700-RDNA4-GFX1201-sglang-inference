+        # last-N recency window (--force-decode-window), the DECODE path reads the K most
+        # query-relevant KV pages (Quest bounding-box criticality) + sink + recent page. Leaves
+        # full kv_indices in the metadata (layers stay full-attention) and SELECTS in forward_decode.
+        # Validated on real keys: 3-11x more attention mass captured than recency (perf-inv #39).
+        # Default -1 (off). v1 = eager on-the-fly reps (cuda-graph auto-disabled in server_args).
+        self.decode_topk_pages = (
+            getattr(model_runner.server_args, "decode_topk_pages", -1) or -1
+        )
+        self.decode_topk_page_size = (
+            getattr(model_runner.server_args, "decode_topk_page_size", 8) or 8
+        )
+        self.decode_topk_scorer = getattr(
+            model_runner.server_args, "decode_topk_scorer", "bbox"
+        )
+        # R9700 #41 v2: cached per-layer page reps (bbox min/max) for the bs==1 fast path.
+        # Built/extended incrementally — a page's rep is computed once when the page COMPLETES
+        # (every page_size decode steps), so steady-state maintenance is O(page) not O(ctx).
+        # Keyed by layer_id; lazily (re)built from full KV on any structural mismatch (safe:
+        # worst case = v1 O(ctx)). Identical per-page min/max to v1 → identical selection/recall.
+        self._topk_pmin = {}
+        self._topk_pmax = {}
+        self._topk_n = {}       # layer_id -> #pages currently repped
+        self._topk_len = {}     # layer_id -> seq_len at last update (staleness detect)
+        self._topk_slot0 = {}   # layer_id -> first physical slot (request-identity, staleness detect)
         # Pool refs — captured at construction so they survive deletion of the
