diff --git a/python/sglang/srt/layers/attention/triton_backend.py b/python/sglang/srt/layers/attention/triton_backend.py
index ed5ac5c84..278678031 100644
--- a/python/sglang/srt/layers/attention/triton_backend.py
+++ b/python/sglang/srt/layers/attention/triton_backend.py
@@ -6,6 +6,38 @@ from typing import TYPE_CHECKING, List, Optional
 
 import torch
 import triton
+import triton.language as tl
+
+
+# R9700 #43 (v3): fused bbox-criticality scorer for #39 top-K sparse KV. Replaces the eager
+# `where(q>=0,q*pmax,q*pmin).sum((1,2))` (which materializes fp32 reps + multiple passes over the
+# dominant rep data) with ONE fused pass. Validated numerically identical ranking, ~11x faster at
+# 256K scale (0.152→0.014 ms/call, n=3828). One program per page; reduces Hkv*D in-register.
+@triton.jit
+def _bbox_crit_kernel(pmin_ptr, pmax_ptr, q_ptr, score_ptr, HD, BLOCK: tl.constexpr):
+    pid = tl.program_id(0)
+    offs = tl.arange(0, BLOCK)
+    mask = offs < HD
+    q = tl.load(q_ptr + offs, mask=mask, other=0.0).to(tl.float32)
+    base = pid * HD
+    pmn = tl.load(pmin_ptr + base + offs, mask=mask, other=0.0).to(tl.float32)
+    pmx = tl.load(pmax_ptr + base + offs, mask=mask, other=0.0).to(tl.float32)
+    crit = tl.where(q >= 0, q * pmx, q * pmn)
+    s = tl.sum(tl.where(mask, crit, 0.0), axis=0)
+    tl.store(score_ptr + pid, s)
+
+
+def fused_bbox_score(pmin, pmax, q_kv):
+    """pmin/pmax [n, Hkv, D], q_kv [Hkv, D] -> criticality score [n] fp32 (one fused pass)."""
+    n, Hkv, D = pmin.shape
+    HD = Hkv * D
+    score = torch.empty(n, device=pmin.device, dtype=torch.float32)
+    _bbox_crit_kernel[(n,)](
+        pmin.reshape(n, HD), pmax.reshape(n, HD), q_kv.reshape(HD).float(),
+        score, HD, BLOCK=triton.next_power_of_2(HD),
+    )
+    return score
+
 
 # RDNA4: opt-in split-KV (flash-decoding) tree-verify kernel for spec-decode (task #10).
 # The default extend verify reads the deep prefix KV unsplit (~2.7s @244K); this splits it
@@ -140,6 +172,31 @@ class TritonAttnBackend(AttentionBackend):
             getattr(model_runner.server_args, "force_verify_window", -1) or -1
         )
         self.verify_sink = getattr(model_runner.server_args, "verify_sink", 0) or 0
