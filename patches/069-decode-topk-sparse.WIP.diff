+    def _build_topk_kv_indices_v2(self, q, layer, kv_indptr, kv_indices):
+        """R9700 #41 v2 fast path (bs==1, bbox): same Quest selection as v1 but page reps are
+        CACHED and extended incrementally — a page's min/max is computed once when it completes
+        (every page_size steps), so per-step cost is O(reps)+O(page) instead of v1's O(ctx).
+        Per-page reps are bit-identical to v1 → identical selection/recall. Falls back to v1 on
+        any structural mismatch. Caller guarantees bs==1 and scorer=='bbox'."""
+        page = self.decode_topk_page_size
+        K_total = self.decode_topk_pages
+        budget = K_total * page
+        L = int(kv_indptr[1] - kv_indptr[0])
+        slots = kv_indices[int(kv_indptr[0]):int(kv_indptr[1])]
+        if L <= budget or L < 2 * page:
+            return kv_indptr, kv_indices  # within budget — keep all
+        n = L // page
+        lid = layer.layer_id
+        k_buffer = self.token_to_kv_pool.get_key_buffer(layer.layer_id)
+        Hkv, D = k_buffer.shape[1], k_buffer.shape[2]
+        Hq = q.shape[1]
+        group = max(1, Hq // Hkv)
+        pmin = self._topk_pmin.get(lid)
+        old_n = self._topk_n.get(lid, 0)
+        tracked = self._topk_len.get(lid, -1)
+        # Rebuild fully if no state, fewer pages stored than needed minus a normal growth step,
+        # the sequence shrank (new request), or a non-incremental jump occurred.
+        rebuild = (
+            pmin is None or old_n > n or tracked > L or tracked < 0
+            or (L - tracked) > 4 * page
+        )
+        # Reps stored in bf16 (half the memory; fp32 reps OOM at depth — 8.6GB @128K page8).
+        # min/max computed in native KV dtype (no full-K fp32 upcast transient); cast to fp32
+        # only the small per-page reps at score time. fp8 KV → cast gather to bf16 for amin/amax.
+        def _pagereps(seg_slots, npg):
+            kb = k_buffer[seg_slots].view(npg, page, Hkv, D)
+            if kb.dtype not in (torch.float16, torch.bfloat16, torch.float32):
+                kb = kb.to(torch.bfloat16)
+            return kb.amin(1).to(torch.bfloat16), kb.amax(1).to(torch.bfloat16)
+        if rebuild:
+            pmin, pmax = _pagereps(slots[:n * page], n)
+        else:
+            pmax = self._topk_pmax[lid]
+            if n > old_n:  # one or more pages completed since last step — rep just those
+                nmin, nmax = _pagereps(slots[old_n * page:n * page], n - old_n)
+                pmin = torch.cat([pmin[:old_n], nmin], dim=0)
+                pmax = torch.cat([pmax[:old_n], nmax], dim=0)
+        self._topk_pmin[lid] = pmin; self._topk_pmax[lid] = pmax
+        self._topk_n[lid] = n; self._topk_len[lid] = L
+        qb = q[0].view(Hkv, group, D).mean(1).float()
+        qv = qb.unsqueeze(0)
+        score = torch.where(qv >= 0, qv * pmax.float(), qv * pmin.float()).sum(dim=(1, 2))  # [n]
+        ksel = max(1, K_total - 2)
+        top = torch.topk(score, min(ksel, n)).indices
+        keep = sorted(set(top.tolist()) | {0, n - 1})
+        parts = [slots[p * page:(p + 1) * page] for p in keep]
+        if n * page < L:
+            parts.append(slots[n * page:])  # recent partial page
+        sel = torch.cat(parts)
+        out_indptr = torch.tensor([0, sel.numel()], dtype=kv_indptr.dtype, device=kv_indptr.device)
+        return out_indptr, sel.to(kv_indices.dtype)
+
+    def _build_topk_kv_indices(self, q, layer, kv_indptr, kv_indices):
+        """R9700 #39 v1 (eager, correctness-first): for each request, score KV pages by Quest
+        bounding-box criticality against the decode query and keep the top-K pages (+ page-0 sink
+        + the most-recent partial page), returning a shortened (kv_indptr, kv_indices) that the
+        existing decode kernel consumes unchanged. O(ctx) per layer per step — slow but correct;
+        the incremental-rep + cuda-graph fast path is the follow-up. Single-user (bs small)."""
+        page = self.decode_topk_page_size
+        K_total = self.decode_topk_pages
+        budget = K_total * page
+        k_buffer = self.token_to_kv_pool.get_key_buffer(layer.layer_id)  # [slots, Hkv, D]
+        Hkv, D = k_buffer.shape[1], k_buffer.shape[2]
+        Hq = q.shape[1]
+        group = max(1, Hq // Hkv)
+        bs = kv_indptr.shape[0] - 1
+        out_indptr = torch.zeros_like(kv_indptr)
+        chunks = []
+        for b in range(bs):
+            s = int(kv_indptr[b]); e = int(kv_indptr[b + 1])
+            slots = kv_indices[s:e]
+            L = slots.numel()
+            if L <= budget or L < 2 * page:
+                sel = slots  # already within budget — keep all
+            else:
+                n = L // page
+                usable = n * page
+                Kb = k_buffer[slots[:usable]].view(n, page, Hkv, D).float()
+                qb = q[b].view(Hkv, group, D).mean(1).float()  # GQA-avg query [Hkv, D]
+                if self.decode_topk_scorer == "centroid":
+                    score = torch.einsum("nhd,hd->n", Kb.mean(1), qb)
+                else:  # bbox (Quest bounding-box criticality)
+                    kmin = Kb.amin(1); kmax = Kb.amax(1)
+                    qv = qb.unsqueeze(0)
+                    score = torch.where(qv >= 0, qv * kmax, qv * kmin).sum(dim=(1, 2))
+                ksel = max(1, K_total - 2)  # reserve a slot for sink + recent pages
+                top = torch.topk(score, min(ksel, n)).indices
+                keep = set(top.tolist()); keep.add(0); keep.add(n - 1)
+                parts = [slots[p * page:(p + 1) * page] for p in sorted(keep)]
+                if usable < L:
+                    parts.append(slots[usable:])  # recent partial page (newest tokens)
+                sel = torch.cat(parts)
+            chunks.append(sel)
+            out_indptr[b + 1] = out_indptr[b] + sel.numel()
+        out_indices = torch.cat(chunks).to(kv_indices.dtype)
+        return out_indptr, out_indices
+
