diff --git a/test/registered/unit/models/test_laguna_router.py b/test/registered/unit/models/test_laguna_router.py
new file mode 100644
--- /dev/null
+++ b/test/registered/unit/models/test_laguna_router.py
@@ -0,0 +1,33 @@
+import unittest
+from types import SimpleNamespace
+
+import torch
+
+from sglang.srt.models.laguna import LagunaMoEGate
+
+
+class TestLagunaRouter(unittest.TestCase):
+    def test_router_uses_checkpoint_dtype_and_returns_fp32_logits(self):
+        config = SimpleNamespace(
+            num_experts=8,
+            hidden_size=16,
+            dtype=torch.bfloat16,
+        )
+        gate = LagunaMoEGate(config)
+        with torch.no_grad():
+            gate.weight.copy_(torch.randn_like(gate.weight))
+        hidden_states = torch.randn(3, 16, dtype=torch.bfloat16)
+
+        self.assertEqual(gate.weight.dtype, torch.bfloat16)
+        output = gate(hidden_states)
+        self.assertEqual(output.dtype, torch.float32)
+        torch.testing.assert_close(
+            output,
+            torch.nn.functional.linear(hidden_states, gate.weight).float(),
+            rtol=0,
+            atol=0,
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()
