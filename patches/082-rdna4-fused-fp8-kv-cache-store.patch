diff --git a/test/registered/jit/test_rdna4_fp8_kv_store.py b/test/registered/jit/test_rdna4_fp8_kv_store.py
new file mode 100644
--- /dev/null
+++ b/test/registered/jit/test_rdna4_fp8_kv_store.py
@@ -0,0 +1,135 @@
+# SPDX-License-Identifier: Apache-2.0
+"""Correctness coverage for the RDNA4 fused static-scale FP8 KV writer."""
+
+import unittest
+
+import torch
+
+from sglang.jit_kernel.triton_store_cache import triton_fused_static_fp8_kv_store
+from sglang.srt.utils import is_hip
+from sglang.test.ci.ci_register import register_amd_ci
+
+register_amd_ci(est_time=10, stage="jit-kernel-unit", runner_config="amd")
+
+
+@unittest.skipUnless(is_hip() and torch.cuda.is_available(), "ROCm GPU required")
+class TestRDNA4FP8KVStore(unittest.TestCase):
+    def test_matches_saturating_torch_path_byte_for_byte(self):
+        dtype = torch.float8_e4m3fn
+        fp8_info = torch.finfo(dtype)
+
+        for num_tokens in (1, 8, 64):
+            with self.subTest(num_tokens=num_tokens):
+                num_heads, head_dim = 4, 128
+                row_dim = num_heads * head_dim
+                packed = (
+                    torch.randn(
+                        num_tokens,
+                        3 * row_dim,
+                        dtype=torch.bfloat16,
+                        device="cuda",
+                    )
+                    * 100
+                )
+                key, value, _ = packed.split([row_dim, row_dim, row_dim], dim=-1)
+                key = key.view(num_tokens, num_heads, head_dim)
+                value = value.view(num_tokens, num_heads, head_dim)
+                key[0, 0, :8] = torch.tensor(
+                    [-1000, -448, -447, -1, 0, 447, 448, 1000],
+                    dtype=torch.bfloat16,
+                    device="cuda",
+                )
+                value[0, 0, :4] = torch.tensor(
+                    [float("-inf"), -500, 500, float("inf")],
+                    dtype=torch.bfloat16,
+                    device="cuda",
+                )
+
+                num_slots = max(128, num_tokens + 16)
+                locations = torch.arange(
+                    3, 3 + num_tokens, dtype=torch.int64, device="cuda"
+                )
+                key_cache = torch.full(
+                    (num_slots, num_heads, head_dim),
+                    0xA5,
+                    dtype=torch.uint8,
+                    device="cuda",
+                )
+                value_cache = key_cache.clone()
+
+                triton_fused_static_fp8_kv_store(
+                    key,
+                    value,
+                    key_cache,
+                    value_cache,
+                    locations,
+                    fp8_dtype=dtype,
+                    k_scale=torch.tensor(0.75, dtype=torch.float32, device="cuda"),
+                    v_scale=torch.tensor(1.25, dtype=torch.float32, device="cuda"),
+                    size_limit=num_slots,
+                )
+
+                expected_key = key.clone()
+                expected_value = value.clone()
+                expected_key.div_(0.75).clamp_(fp8_info.min, fp8_info.max)
+                expected_value.div_(1.25).clamp_(fp8_info.min, fp8_info.max)
+                expected_key = expected_key.to(dtype).view(torch.uint8)
+                expected_value = expected_value.to(dtype).view(torch.uint8)
+
+                torch.testing.assert_close(
+                    key_cache[locations], expected_key, rtol=0, atol=0
+                )
+                torch.testing.assert_close(
+                    value_cache[locations], expected_value, rtol=0, atol=0
+                )
+                self.assertTrue(torch.all(key_cache[:3] == 0xA5).item())
+                self.assertTrue(torch.all(value_cache[:3] == 0xA5).item())
+
+    def test_unscaled_path_matches_direct_fp8_cast(self):
+        dtype = torch.float8_e4m3fn
+        num_tokens, num_heads, head_dim, num_slots = 8, 4, 128, 32
+        packed = torch.randn(
+            num_tokens,
+            3 * num_heads * head_dim,
+            dtype=torch.bfloat16,
+            device="cuda",
+        )
+        key, value, _ = packed.split(
+            [num_heads * head_dim] * 3,
+            dim=-1,
+        )
+        key = key.view(num_tokens, num_heads, head_dim)
+        value = value.view(num_tokens, num_heads, head_dim)
+        locations = torch.arange(
+            2, 2 + num_tokens, dtype=torch.int32, device="cuda"
+        )
+        key_cache = torch.zeros(
+            num_slots, num_heads, head_dim, dtype=torch.uint8, device="cuda"
+        )
+        value_cache = torch.zeros_like(key_cache)
+
+        triton_fused_static_fp8_kv_store(
+            key,
+            value,
+            key_cache,
+            value_cache,
+            locations,
+            fp8_dtype=dtype,
+            k_scale=None,
+            v_scale=None,
+            size_limit=num_slots,
+        )
+
+        torch.testing.assert_close(
+            key_cache[locations], key.to(dtype).view(torch.uint8), rtol=0, atol=0
+        )
+        torch.testing.assert_close(
+            value_cache[locations],
+            value.to(dtype).view(torch.uint8),
+            rtol=0,
+            atol=0,
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()
