--- a/python/sglang/jit_kernel/triton_store_cache.py
+++ b/python/sglang/jit_kernel/triton_store_cache.py
@@ -235,3 +235,123 @@ def triton_fused_store_cache(
         triton_fused_store_flashmla(input, cache, indices, page_size)
     else:
         triton_fused_store_indexer(input, cache, indices, page_size)
+
+
+@triton.jit
+def _triton_fused_static_fp8_kv_store_kernel(
+    key_ptr,
+    value_ptr,
+    key_cache_ptr,
+    value_cache_ptr,
+    indices_ptr,
+    row_dim,
+    key_token_stride,
+    value_token_stride,
+    size_limit,
+    k_scale,
+    v_scale,
+    FP8_MIN: tl.constexpr,
+    FP8_MAX: tl.constexpr,
+    BLOCK: tl.constexpr,
+    USE_K_SCALE: tl.constexpr,
+    USE_V_SCALE: tl.constexpr,
+    K_SCALE_IS_TENSOR: tl.constexpr,
+    V_SCALE_IS_TENSOR: tl.constexpr,
+):
+    """Scale, saturate, cast, and scatter one ordinary MHA K/V row."""
+    token_id = tl.program_id(0)
+    block_id = tl.program_id(1)
+    cols = block_id * BLOCK + tl.arange(0, BLOCK)
+    loc = tl.load(indices_ptr + token_id)
+    mask = (cols < row_dim) & (loc >= 0) & (loc < size_limit)
+
+    key = tl.load(
+        key_ptr + token_id * key_token_stride + cols, mask=mask, other=0.0
+    ).to(tl.float32)
+    value = tl.load(
+        value_ptr + token_id * value_token_stride + cols, mask=mask, other=0.0
+    ).to(tl.float32)
+    if USE_K_SCALE:
+        if K_SCALE_IS_TENSOR:
+            key /= tl.load(k_scale)
+        else:
+            key /= k_scale
+    if USE_V_SCALE:
+        if V_SCALE_IS_TENSOR:
+            value /= tl.load(v_scale)
+        else:
+            value /= v_scale
+
+    key = tl.clamp(key, FP8_MIN, FP8_MAX).to(key_cache_ptr.dtype.element_ty)
+    value = tl.clamp(value, FP8_MIN, FP8_MAX).to(
+        value_cache_ptr.dtype.element_ty
+    )
+    dst = loc * row_dim + cols
+    tl.store(key_cache_ptr + dst, key, mask=mask)
+    tl.store(value_cache_ptr + dst, value, mask=mask)
+
+
+def triton_fused_static_fp8_kv_store(
+    key: torch.Tensor,
+    value: torch.Tensor,
+    key_cache: torch.Tensor,
+    value_cache: torch.Tensor,
+    indices: torch.Tensor,
+    *,
+    fp8_dtype: torch.dtype,
+    k_scale: float | torch.Tensor | None,
+    v_scale: float | torch.Tensor | None,
+    size_limit: int,
+) -> None:
+    """Fused static-scale FP8 quantization and NHD cache scatter.
+
+    ``key_cache`` and ``value_cache`` may use uint8 storage; typed FP8 views
+    ensure Triton writes the floating-point encodings rather than numeric uint8
+    conversions. Source token rows may be strided QKV split views, but their
+    head/dimension payload must be contiguous.
+    """
+    if key.shape[0] == 0:
+        return
+    if key.shape != value.shape or key.ndim != 3:
+        raise ValueError(
+            "fused FP8 KV store requires matching [tokens, heads, dim] inputs, "
+            f"got key={tuple(key.shape)} and value={tuple(value.shape)}"
+        )
+    if key.stride(2) != 1 or value.stride(2) != 1:
+        raise ValueError("fused FP8 KV store requires contiguous head dimensions")
+    if key.stride(1) != key.shape[2] or value.stride(1) != value.shape[2]:
+        raise ValueError(
+            "fused FP8 KV store requires contiguous rows within a token"
+        )
+
+    row_dim = key.shape[1] * key.shape[2]
+    block = min(triton.next_power_of_2(row_dim), 1024)
+    fp8_info = torch.finfo(fp8_dtype)
+    key_cache_fp8 = key_cache.view(fp8_dtype)
+    value_cache_fp8 = value_cache.view(fp8_dtype)
+    k_scale_is_tensor = isinstance(k_scale, torch.Tensor)
+    v_scale_is_tensor = isinstance(v_scale, torch.Tensor)
+
+    _triton_fused_static_fp8_kv_store_kernel[
+        (key.shape[0], triton.cdiv(row_dim, block))
+    ](
+        key,
+        value,
+        key_cache_fp8,
+        value_cache_fp8,
+        indices,
+        row_dim,
+        key.stride(0),
+        value.stride(0),
+        size_limit,
+        key if k_scale is None else k_scale,
+        value if v_scale is None else v_scale,
+        FP8_MIN=fp8_info.min,
+        FP8_MAX=fp8_info.max,
+        BLOCK=block,
+        USE_K_SCALE=(k_scale is not None),
+        USE_V_SCALE=(v_scale is not None),
+        K_SCALE_IS_TENSOR=k_scale_is_tensor,
+        V_SCALE_IS_TENSOR=v_scale_is_tensor,
+        num_warps=8 if block >= 512 else 4,
+    )
