diff --git a/test/registered/unit/batch_invariant_ops/test_batch_invariant_ops_config.py b/test/registered/unit/batch_invariant_ops/test_batch_invariant_ops_config.py
new file mode 100644
index 0000000000..c6fe8f5909
--- /dev/null
+++ b/test/registered/unit/batch_invariant_ops/test_batch_invariant_ops_config.py
@@ -0,0 +1,52 @@
+import unittest
+from unittest.mock import patch
+
+import torch
+
+from sglang.srt.batch_invariant_ops import batch_invariant_ops
+from sglang.test.ci.ci_register import register_cpu_ci
+
+register_cpu_ci(est_time=2, suite="base-a-test-cpu")
+
+
+class TestBatchInvariantMatmulConfig(unittest.TestCase):
+    def test_hip_uses_two_pipeline_stages_for_every_supported_dtype(self):
+        with patch.object(batch_invariant_ops, "_is_hip", True):
+            for dtype in (torch.float16, torch.bfloat16, torch.float32):
+                with self.subTest(dtype=dtype):
+                    config = batch_invariant_ops._get_batch_invariant_matmul_config(
+                        dtype
+                    )
+                    self.assertEqual(config["num_stages"], 2)
+
+    def test_non_hip_preserves_the_existing_three_stage_configs(self):
+        expected_tiles = {
+            torch.float16: (128, 256, 64),
+            torch.bfloat16: (128, 128, 64),
+            torch.float32: (128, 128, 32),
+        }
+        with patch.object(batch_invariant_ops, "_is_hip", False):
+            for dtype, expected_tile in expected_tiles.items():
+                with self.subTest(dtype=dtype):
+                    config = batch_invariant_ops._get_batch_invariant_matmul_config(
+                        dtype
+                    )
+                    self.assertEqual(config["num_stages"], 3)
+                    self.assertEqual(
+                        (
+                            config["BLOCK_SIZE_M"],
+                            config["BLOCK_SIZE_N"],
+                            config["BLOCK_SIZE_K"],
+                        ),
+                        expected_tile,
+                    )
+                    self.assertEqual(config["GROUP_SIZE_M"], 8)
+                    self.assertEqual(config["num_warps"], 8)
+
+    def test_unsupported_dtype_is_rejected_before_kernel_launch(self):
+        with self.assertRaisesRegex(ValueError, "Unsupported dtype"):
+            batch_invariant_ops._get_batch_invariant_matmul_config(torch.int32)
+
+
+if __name__ == "__main__":
+    unittest.main()
