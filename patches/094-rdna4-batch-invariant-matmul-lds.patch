+def _get_batch_invariant_matmul_config(dtype: torch.dtype) -> Dict[str, int]:
+    """Return the fixed MM/BMM tile while respecting the HIP LDS limit.
+
+    Triton's three-stage pipeline needs 98,816 bytes for the FP16 tile and
+    65,792 bytes for the BF16 tile on gfx1201. Both exceed its 65,536-byte
+    per-workgroup limit. Two stages preserve the fixed reduction order used
+    for batch invariance while reducing those footprints to 49,664 and 33,024
+    bytes respectively.
+    """
+    configs = {
+        torch.bfloat16: {
+            "BLOCK_SIZE_M": 128,
+            "BLOCK_SIZE_N": 128,
+            "BLOCK_SIZE_K": 64,
+            "GROUP_SIZE_M": 8,
+            "num_warps": 8,
+        },
+        torch.float16: {
+            "BLOCK_SIZE_M": 128,
+            "BLOCK_SIZE_N": 256,
+            "BLOCK_SIZE_K": 64,
+            "GROUP_SIZE_M": 8,
+            "num_warps": 8,
+        },
+        torch.float32: {
+            "BLOCK_SIZE_M": 128,
+            "BLOCK_SIZE_N": 128,
+            "BLOCK_SIZE_K": 32,
+            "GROUP_SIZE_M": 8,
+            "num_warps": 8,
+        },
+    }
+    config = configs.get(dtype)
+    if config is None:
+        raise ValueError(
+            f"Unsupported dtype {dtype} for batch-invariant matrix multiplication. "
+            f"Supported dtypes are: {list(configs.keys())}"
+        )
+    return {**config, "num_stages": 2 if _is_hip else 3}
+
