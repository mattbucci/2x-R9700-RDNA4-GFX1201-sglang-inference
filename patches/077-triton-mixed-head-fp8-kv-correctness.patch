@@ -0,0 +1,61 @@
+import unittest
+from types import SimpleNamespace
+
+import torch
+
+from sglang.srt.layers.attention.triton_backend import (
+    _get_kv_cache_descales,
+    _max_num_attention_heads,
+)
+
+
+class TestMaxNumAttentionHeads(unittest.TestCase):
+    def test_uses_global_head_count_for_uniform_models(self):
+        config = SimpleNamespace(num_attention_heads=48, hf_config=SimpleNamespace())
+        self.assertEqual(_max_num_attention_heads(config), 48)
+
+    def test_uses_largest_per_layer_head_count(self):
+        config = SimpleNamespace(
+            num_attention_heads=48,
+            hf_config=SimpleNamespace(
+                num_attention_heads_per_layer=[48, 64, 64, 64]
+            ),
+        )
+        self.assertEqual(_max_num_attention_heads(config), 64)
+
+    def test_prefers_normalized_model_config_field(self):
+        config = SimpleNamespace(
+            num_attention_heads=32,
+            num_attention_heads_per_layer=[32, 40],
+            hf_config=SimpleNamespace(num_attention_heads_per_layer=[32, 64]),
+        )
+        self.assertEqual(_max_num_attention_heads(config), 40)
+
+
+class TestKVCacheDescales(unittest.TestCase):
+    def setUp(self):
+        self.layer = SimpleNamespace(
+            k_scale=object(),
+            v_scale=object(),
+            k_scale_float=0.00125,
+            v_scale_float=0.0025,
+        )
+
+    def test_uses_checkpoint_scales_for_fp8_cache(self):
+        pool = SimpleNamespace(dtype=torch.float8_e4m3fn)
+        self.assertEqual(
+            _get_kv_cache_descales(self.layer, pool), (0.00125, 0.0025)
+        )
+
+    def test_ignores_checkpoint_scales_for_bf16_override(self):
+        pool = SimpleNamespace(dtype=torch.bfloat16)
+        self.assertEqual(_get_kv_cache_descales(self.layer, pool), (1.0, 1.0))
+
+    def test_missing_checkpoint_scales_use_identity(self):
+        self.layer.k_scale = None
+        pool = SimpleNamespace(dtype=torch.float8_e4m3fn)
+        self.assertEqual(_get_kv_cache_descales(self.layer, pool), (1.0, 1.0))
+
+
+if __name__ == "__main__":
+    unittest.main()
diff --git a/test/registered/unit/test_kv_cache_dtype_handling.py b/test/registered/unit/test_kv_cache_dtype_handling.py
new file mode 100644
index 0000000000..a9cca8f36d
--- /dev/null
+++ b/test/registered/unit/test_kv_cache_dtype_handling.py
@@ -0,0 +1,83 @@
+"""CPU regression coverage for KV-cache casting and static FP8 scales."""
+
+import unittest
+from types import SimpleNamespace
+from unittest import mock
+
+import torch
+
+from sglang.srt.mem_cache.memory_pool import MHATokenToKVPool
+from sglang.test.ci.ci_register import register_cpu_ci
+
+register_cpu_ci(est_time=5, suite="base-a-test-cpu")
+
+
+def _make_pool(dtype):
+    return MHATokenToKVPool(
+        size=2,
+        page_size=1,
+        dtype=dtype,
+        head_num=1,
+        head_dim=4,
+        layer_num=1,
+        device="cpu",
+        enable_memory_saver=False,
+        enable_alt_stream=False,
+    )
+
+
+class TestKVCacheDtypeHandling(unittest.TestCase):
+    def test_fp8_write_saturates_out_of_range_values(self):
+        pool = _make_pool(torch.float8_e4m3fn)
+        k = torch.tensor([[[1000.0, -1000.0, 300.0, -300.0]]])
+        v = torch.tensor([[[2000.0, -2000.0, 100.0, -100.0]]])
+
+        with mock.patch(
+            "sglang.srt.mem_cache.memory_pool.can_use_store_cache",
+            return_value=False,
+        ):
+            pool.set_kv_buffer(
+                SimpleNamespace(layer_id=0),
+                torch.tensor([1]),
+                k,
+                v,
+                k_scale=0.5,
+                v_scale=0.25,
+            )
+
+        cached_k, cached_v = pool.get_kv_buffer(0)
+        cached_k = cached_k[1].float()
+        cached_v = cached_v[1].float()
+        limit = torch.finfo(torch.float8_e4m3fn).max
+        self.assertTrue(torch.isfinite(cached_k).all())
+        self.assertTrue(torch.isfinite(cached_v).all())
+        self.assertLessEqual(cached_k.abs().max().item(), limit)
+        self.assertLessEqual(cached_v.abs().max().item(), limit)
+        self.assertEqual(cached_k[0, 0].item(), limit)
+        self.assertEqual(cached_v[0, 0].item(), limit)
+
+    def test_bf16_override_does_not_apply_fp8_checkpoint_scales(self):
+        pool = _make_pool(torch.bfloat16)
+        k = torch.tensor([[[1.0, 2.0, 3.0, 4.0]]])
+        v = torch.tensor([[[5.0, 6.0, 7.0, 8.0]]])
+
+        with mock.patch(
+            "sglang.srt.mem_cache.memory_pool.can_use_store_cache",
+            return_value=False,
+        ):
+            pool.set_kv_buffer(
+                SimpleNamespace(layer_id=0),
+                torch.tensor([1]),
+                k,
+                v,
+                k_scale=0.001,
+                v_scale=0.002,
+            )
+
+        cached_k, cached_v = pool.get_kv_buffer(0)
+        torch.testing.assert_close(cached_k[1].float(), k[0], rtol=0, atol=0)
+        torch.testing.assert_close(cached_v[1].float(), v[0], rtol=0, atol=0)
+
+
+if __name__ == "__main__":
+    unittest.main()

