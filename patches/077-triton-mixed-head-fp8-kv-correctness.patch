+def _max_num_attention_heads(model_config) -> int:
+    """Return the largest query-head count used by any attention layer.
+
+    Most architectures use one global head count, but Laguna uses fewer query
+    heads in full-attention layers than in sliding-window layers.  Decode
+    scratch buffers are shared across layers, so they must be sized for the
+    largest layer rather than only ``config.num_attention_heads``.
+    """
+    default = model_config.num_attention_heads
+    per_layer = getattr(model_config, "num_attention_heads_per_layer", None)
+    if per_layer is None:
+        per_layer = getattr(
+            getattr(model_config, "hf_config", None),
+            "num_attention_heads_per_layer",
+            None,
+        )
+    return max(per_layer) if per_layer else default
+
+
+def _kv_cache_uses_fp8(token_to_kv_pool) -> bool:
+    return getattr(token_to_kv_pool, "dtype", None) in _FP8_KV_CACHE_DTYPES
+
+
+def _get_kv_cache_descales(layer, token_to_kv_pool):
+    """Return checkpoint KV descales only when the physical cache is FP8.
+
+    Quantized checkpoints can carry static K/V scales even when the operator
+    overrides ``--kv-cache-dtype`` to BF16.  Applying those scales while
+    reading an unscaled BF16 cache shrinks attention values by roughly 1e3.
+    """
+    if (
+        _kv_cache_uses_fp8(token_to_kv_pool)
+        and layer.k_scale is not None
+        and layer.v_scale is not None
+    ):
+        return layer.k_scale_float, layer.v_scale_float
+    return 1.0, 1.0
+
