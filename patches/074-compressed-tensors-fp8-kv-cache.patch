--- /dev/null
+++ b/test/registered/unit/layers/quantization/test_compressed_tensors_kv_cache.py
@@ -0,0 +1,153 @@
+"""CPU coverage for compressed-tensors FP8 KV-cache metadata and scales."""
+
+import unittest
+from types import SimpleNamespace
+from unittest import mock
+
+import torch
+
+from sglang.test.ci.ci_register import register_cpu_ci
+
+register_cpu_ci(est_time=5, suite="base-a-test-cpu")
+
+from sglang.srt.layers.quantization.compressed_tensors.compressed_tensors import (
+    CompressedTensorsConfig,
+    CompressedTensorsKVCacheMethod,
+)
+from sglang.srt.layers.radix_attention import RadixAttention
+from sglang.srt.models.laguna import LagunaForCausalLM
+from sglang.test.test_utils import CustomTestCase
+
+
+def _make_config(kv_cache_scheme=None):
+    config = {
+        "quant_method": "compressed-tensors",
+        "format": "float-quantized",
+        "config_groups": {},
+        "ignore": [],
+    }
+    if kv_cache_scheme is not None:
+        config["kv_cache_scheme"] = kv_cache_scheme
+    return config
+
+
+FP8_TENSOR_KV_SCHEME = {
+    "num_bits": 8,
+    "type": "float",
+    "strategy": "tensor",
+    "symmetric": True,
+    "dynamic": False,
+}
+
+
+class TestCompressedTensorsKVCache(CustomTestCase):
+    def test_config_preserves_fp8_kv_scheme_and_selects_fp8_pool(self):
+        quant_config = CompressedTensorsConfig.from_config(
+            _make_config(FP8_TENSOR_KV_SCHEME)
+        )
+
+        self.assertEqual(quant_config.kv_cache_scheme, FP8_TENSOR_KV_SCHEME)
+        self.assertEqual(quant_config.kv_cache_quant_algo, "FP8")
+
+    def test_laguna_exposes_quant_config_for_kv_cache_auto_selection(self):
+        quant_config = CompressedTensorsConfig.from_config(
+            _make_config(FP8_TENSOR_KV_SCHEME)
+        )
+        model_body = torch.nn.Module()
+        model_body.layers = torch.nn.ModuleList()
+        model_body.start_layer = 0
+        model_body.end_layer = 0
+
+        with (
+            mock.patch(
+                "sglang.srt.models.laguna.get_pp_group",
+                return_value=SimpleNamespace(is_last_rank=False),
+            ),
+            mock.patch(
+                "sglang.srt.models.laguna.LagunaModel", return_value=model_body
+            ),
+            mock.patch(
+                "sglang.srt.models.laguna.PPMissingLayer",
+                return_value=torch.nn.Identity(),
+            ),
+            mock.patch("sglang.srt.models.laguna.LogitsProcessor"),
+        ):
+            model = LagunaForCausalLM(SimpleNamespace(), quant_config=quant_config)
+
+        self.assertIs(model.quant_config, quant_config)
+        self.assertEqual(model.quant_config.kv_cache_quant_algo, "FP8")
+
+    def test_radix_attention_creates_and_processes_static_scales(self):
+        quant_config = CompressedTensorsConfig.from_config(
+            _make_config(FP8_TENSOR_KV_SCHEME)
+        )
+        layer = RadixAttention(
+            num_heads=2,
+            head_dim=8,
+            scaling=8**-0.5,
+            num_kv_heads=1,
+            layer_id=0,
+            quant_config=quant_config,
+            prefix="model.layers.0.self_attn.attn",
+        )
+
+        self.assertIsInstance(layer.quant_method, CompressedTensorsKVCacheMethod)
+        self.assertEqual(layer.k_scale.item(), -1.0)
+        self.assertEqual(layer.v_scale.item(), -1.0)
+
+        layer.k_scale.data.fill_(0.25)
+        layer.v_scale.data.fill_(0.5)
+        layer.quant_method.process_weights_after_loading(layer)
+        self.assertEqual(layer.k_scale_float, 0.25)
+        self.assertEqual(layer.v_scale_float, 0.5)
+
+    def test_laguna_loader_remaps_checkpoint_scale_names(self):
+        model = LagunaForCausalLM.__new__(LagunaForCausalLM)
+        torch.nn.Module.__init__(model)
+        model.config = SimpleNamespace(
+            num_experts=0,
+            mlp_layer_types=["dense"],
+            tie_word_embeddings=False,
+        )
+
+        decoder = torch.nn.Module()
+        decoder.self_attn = torch.nn.Module()
+        decoder.self_attn.attn = torch.nn.Module()
+        decoder.self_attn.attn.register_parameter(
+            "k_scale",
+            torch.nn.Parameter(torch.tensor(-1.0), requires_grad=False),
+        )
+        decoder.self_attn.attn.register_parameter(
+            "v_scale",
+            torch.nn.Parameter(torch.tensor(-1.0), requires_grad=False),
+        )
+        decoder.mlp = torch.nn.Identity()
+
+        model.model = torch.nn.Module()
+        model.model.layers = torch.nn.ModuleList([decoder])
+        model.model.start_layer = 0
+        model.model.end_layer = 1
+
+        model.load_weights(
+            [
+                ("model.layers.0.self_attn.k_scale", torch.tensor(0.125)),
+                ("model.layers.0.self_attn.v_scale", torch.tensor(0.375)),
+            ]
+        )
+
+        self.assertEqual(decoder.self_attn.attn.k_scale.item(), 0.125)
+        self.assertEqual(decoder.self_attn.attn.v_scale.item(), 0.375)
+
+    def test_rejects_non_tensor_kv_scales(self):
+        unsupported = dict(FP8_TENSOR_KV_SCHEME, strategy="attn_head")
+        with self.assertRaisesRegex(NotImplementedError, "per-tensor"):
+            CompressedTensorsConfig.from_config(_make_config(unsupported))
+
+    def test_config_without_kv_scheme_keeps_existing_behavior(self):
+        quant_config = CompressedTensorsConfig.from_config(_make_config())
+        self.assertIsNone(quant_config.kv_cache_scheme)
+        self.assertIsNone(quant_config.kv_cache_quant_algo)
+
+
+if __name__ == "__main__":
+    unittest.main()

