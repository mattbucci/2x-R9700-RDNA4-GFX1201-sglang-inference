+            if name.startswith("model.") and not name.startswith(
+                ("model.language_model.", "model.multi_modal_projector.", "model.vision_tower.")
+            ):
+                name = "language_model." + name  # model.X → language_model.model.X
+
+            # Remap bare "lm_head.*" → "language_model.lm_head.*"
+            if name.startswith("lm_head."):
+                name = "language_model." + name
+
+            # Handle both "vision_tower.X" and "model.vision_tower.X" formats
+            # Some checkpoints (androiddrew Devstral AWQ) use "model." prefix
+            if name.startswith("model.vision_tower."):
+                name = name[len("model."):]  # model.vision_tower.X → vision_tower.X
+            if name.startswith("model.multi_modal_projector."):
+                name = name[len("model."):]  # model.multi_modal_projector.X → multi_modal_projector.X
+
+            # Cast BF16 vision/projector weights to model dtype (FP16)
+            # AWQ checkpoints may store vision weights in BF16 while language
