+        # Load weights with prefix remapping for AWQ checkpoints
+        # Some checkpoints (e.g. Devstral AWQ) store language model weights
+        # under "model.*" instead of "language_model.model.*", and "lm_head.*"
+        # instead of "language_model.lm_head.*".
         for name, loaded_weight in weights:
+            # Remap bare "model.*" → "language_model.model.*" when it is
