+            if (name.startswith("vision_tower.") or name.startswith("multi_modal_projector.")):
+                if loaded_weight.dtype == torch.bfloat16:
+                    loaded_weight = loaded_weight.to(torch.float16)
+
             for part in ("language_model", "vision_tower"):
                 if name.startswith(part):
                     name = name[len(part + ".") :]
                     getattr(self, part).load_weights([(name, loaded_weight)])
                     break
             else:
-                param = params_dict[name]
+                # multi_modal_projector weights go to params_dict directly
+                param = params_dict.get(name)
+                if param is None:
+                    logger.warning(f"Skipping unknown weight: {name}")
+                    continue
                 weight_loader = getattr(param, "weight_loader", default_weight_loader)
                 weight_loader(param, loaded_weight)
 
