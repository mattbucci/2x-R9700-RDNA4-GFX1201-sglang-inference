+                                       M, K, top_k, intermediate)
+
+    def _apply_hip_gemv(self, layer, x, topk_weights, topk_ids,
+                        M, K, top_k, intermediate):
+        """Fused MoE via HIP GEMV — all experts dispatched in a single GPU kernel."""
+        from sglang.srt.layers.moe.token_dispatcher import StandardCombineInput
+
+        num_slots = M * top_k
+        sorted_ids = torch.arange(num_slots, dtype=torch.int32, device=x.device)
+        expert_ids_flat = topk_ids.reshape(-1).int()
+        weights_flat = topk_weights.reshape(-1).float()
+
+        # Step 1: Gate+Up GEMV (all experts, one kernel launch)
+        gate_up_N = layer.w13_qweight.shape[2] * 8
+        gate_up = torch.empty(num_slots, gate_up_N, dtype=x.dtype, device=x.device)
+        awq_gemv_hip_ext.awq_gemv_moe_hip(
+            x, layer.w13_qweight, layer.w13_scales, layer.w13_qzeros,
+            gate_up, sorted_ids, expert_ids_flat, weights_flat,
+            top_k, False, 0)
+
+        # Step 2: SiLU activation
+        gate = gate_up[:, :intermediate]
+        up = gate_up[:, intermediate:]
+        activated = (torch.nn.functional.silu(gate) * up).contiguous()
+
+        # Step 3: Down GEMV with routing weight applied (top_k=1: each slot is
+        # an independent token since each has unique activated features)
+        down_out = torch.zeros(num_slots, K, dtype=x.dtype, device=x.device)
+        awq_gemv_hip_ext.awq_gemv_moe_hip(
+            activated, layer.w2_qweight, layer.w2_scales, layer.w2_qzeros,
+            down_out, sorted_ids, expert_ids_flat, weights_flat,
+            1, True, 0)
+
+        # Combine: sum weighted expert outputs per token
+        output = down_out.reshape(M, top_k, K).sum(dim=1)
+        return StandardCombineInput(hidden_states=output)
+
+    def _apply_triton_loop(self, layer, x, topk_weights, topk_ids,
+                           M, K, top_k, intermediate):
+        """Fallback: per-expert dequant+matmul loop (used if HIP kernel unavailable)."""
+        from sglang.srt.layers.moe.token_dispatcher import StandardCombineInput
+
+        num_experts = layer.w13_qweight.shape[0]
+        output = torch.zeros_like(x)
+
+        for expert_id in range(num_experts):
+            mask = (topk_ids == expert_id)
+            if not mask.any():
+                continue
+
+            token_indices, slot_indices = mask.nonzero(as_tuple=True)
+            weights = topk_weights[token_indices, slot_indices]
+            expert_input = x[token_indices]
+
+            # Dequant + matmul (no Triton — avoids gfx1201 HSACO crash)
+            w13_fp16 = awq_dequantize_decomposition(
+                layer.w13_qweight[expert_id], layer.w13_scales[expert_id],
+                layer.w13_qzeros[expert_id])
+            gate_up = torch.matmul(expert_input, w13_fp16)
+
+            gate = gate_up[:, :intermediate]
+            up = gate_up[:, intermediate:]
+            activated = torch.nn.functional.silu(gate) * up
+
+            w2_fp16 = awq_dequantize_decomposition(
+                layer.w2_qweight[expert_id], layer.w2_scales[expert_id],
+                layer.w2_qzeros[expert_id])
+            expert_output = torch.matmul(activated, w2_fp16)
+
+            expert_output = expert_output * weights.unsqueeze(-1)
+            output.index_add_(0, token_indices, expert_output.to(output.dtype))
+
+        return StandardCombineInput(hidden_states=output)
