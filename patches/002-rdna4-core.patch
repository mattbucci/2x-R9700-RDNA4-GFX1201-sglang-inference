+def awq_gemv_triton(
+    input: torch.Tensor,
+    qweight: torch.Tensor,
+    scales: torch.Tensor,
+    qzeros: torch.Tensor,
+    split_k_iters: int = 16,
+    block_size_n: int = 64,
+    block_size_k: int = 64,
