+def _set_laguna_regex_preservation_default(
+    tokenizer_name, kwargs, tokenizer_revision=None
+):
+    """Keep Laguna's custom training-time pre-tokenizer unchanged.
+
+    Transformers may mistake a local large-vocabulary checkpoint without a
+    ``transformers_version`` field for an affected Mistral tokenizer. Laguna
+    trains its own tokenizer, so opt out of that rewrite unless the caller
+    explicitly requests otherwise.
+    """
+    if "fix_mistral_regex" in kwargs:
+        return
+
+    revision = kwargs.get("revision") or tokenizer_revision
+    try:
+        config_file = _resolve_local_or_cached_file(
+            tokenizer_name, "config.json", revision
+        )
+        with open(config_file) as f:
+            config = json.load(f)
+    except (OSError, ValueError):
+        return
+
+    if isinstance(config, dict) and config.get("model_type") == "laguna":
+        kwargs["fix_mistral_regex"] = False
+
+
