 # ---------------------------------------------------------------------------
+# Laguna tokenizer regex preservation
+# ---------------------------------------------------------------------------
+
+
+class TestLagunaTokenizerRegexPreservation(unittest.TestCase):
+    def _load_with_mocked_tokenizers(self, model_type, **kwargs):
+        generic_tokenizer = type("TokenizersBackend", (), {})()
+        resolved_tokenizer = object()
+
+        with tempfile.TemporaryDirectory() as model_dir:
+            with open(f"{model_dir}/config.json", "w") as f:
+                json.dump({"model_type": model_type}, f)
+
+            with (
+                mock.patch.object(
+                    tokenizer_utils,
+                    "_auto_tokenizer_from_pretrained",
+                    return_value=generic_tokenizer,
+                ) as auto_load,
+                mock.patch.object(
+                    tokenizer_utils,
+                    "_resolve_tokenizers_backend",
+                    return_value=resolved_tokenizer,
+                ) as backend_load,
+                mock.patch.object(
+                    tokenizer_utils,
+                    "_apply_post_load_fixes",
+                    side_effect=lambda tokenizer, *_: tokenizer,
+                ),
+            ):
+                result = tokenizer_utils.get_tokenizer(model_dir, **kwargs)
+
+        self.assertIs(result, resolved_tokenizer)
+        return auto_load.call_args.kwargs, backend_load.call_args.kwargs
+
+    def test_laguna_preserves_checkpoint_regex_for_all_load_attempts(self):
+        auto_kwargs, backend_kwargs = self._load_with_mocked_tokenizers("laguna")
+
+        self.assertIs(auto_kwargs["fix_mistral_regex"], False)
+        self.assertIs(backend_kwargs["fix_mistral_regex"], False)
+
+    def test_explicit_laguna_override_wins(self):
+        auto_kwargs, backend_kwargs = self._load_with_mocked_tokenizers(
+            "laguna", fix_mistral_regex=True
+        )
+
+        self.assertIs(auto_kwargs["fix_mistral_regex"], True)
+        self.assertIs(backend_kwargs["fix_mistral_regex"], True)
+
+    def test_non_laguna_tokenizer_is_unchanged(self):
+        auto_kwargs, backend_kwargs = self._load_with_mocked_tokenizers("mistral")
+
+        self.assertNotIn("fix_mistral_regex", auto_kwargs)
+        self.assertNotIn("fix_mistral_regex", backend_kwargs)
+
