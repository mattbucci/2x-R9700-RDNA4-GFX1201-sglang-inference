+
+    def relu2(x: torch.Tensor) -> torch.Tensor:
+        # RDNA4/gfx12xx: the native `relu2` op is CUDA-only (imported from
+        # sglang.jit_kernel.activation under _is_cuda); it is NOT in the HIP
+        # sgl_kernel build, so ReLU2.forward_cuda() would NameError on RDNA4
+        # (hit by nemotron_h's squared-ReLU MLP). Torch fallback == ReLU2's own
+        # forward_native (max(0,x)^2).
+        x = F.relu(x)
+        return x * x
+
