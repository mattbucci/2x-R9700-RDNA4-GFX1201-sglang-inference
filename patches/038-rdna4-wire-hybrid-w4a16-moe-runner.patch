# 038-rdna4-wire-hybrid-w4a16-moe-runner.patch
#
# Wire the wvSplitK INT4 MoE kernel (added by patch 032) into SGLang's
# MoeRunner so MoeWNA16Method can dispatch decode-batch (M≤5) through HIP
# wvSplitK and prefill through Triton fallback, gated by SGLANG_MOE_HYBRID_W4A16.
#
# Pre-existing state (patch 032 partially applied):
#   - hybrid_w4a16_moe.py landed (the standalone `hybrid_w4a16_moe_apply`)
#   - skinny_gemms_int4.cu kernel landed + builds via scripts/build_skinny_gemms_int4.sh
#   - environ.py env-var registration DID NOT land (this patch fixes that)
#   - hybrid_w4a16_moe.py used `.value` for env access; SGLang API is `.get()`
#     (this patch fixes that)
#
# This patch adds:
#   - environ.py:160 — register SGLANG_MOE_HYBRID_W4A16 (default True) +
#     SGLANG_MOE_HYBRID_W4A16_MAX_BATCH (default 5).
#   - utils.py:81 — add MoeRunnerBackend.HYBRID_W4A16 + is_hybrid_w4a16() helper.
#   - moe_runner/runner.py:50 — dispatch branch: when backend is HYBRID_W4A16,
#     side-effect-import the new moe_runner/hybrid_w4a16 module (which registers
#     the fused func), set runner_core = None.
#   - moe_runner/hybrid_w4a16.py — NEW file. `@register_fused_func("none",
#     "hybrid_w4a16")` decorated callable that builds moe_align metadata +
#     invokes hybrid_w4a16_moe_apply with the layer's existing TritonMoeQuantInfo.
#   - hybrid_w4a16_moe.py:230 — fix `.value` → `.get()` (SGLang env API).
#   - moe_wna16.py:365 — env-gated backend selection: prefer HYBRID_W4A16 on
#     ROCm when SGLANG_MOE_HYBRID_W4A16=true AND skinny_gemms_int4_ext is
#     importable. Falls back to TRITON silently otherwise.
#
# Known caveat (deferred to follow-on patch): wvSplitK expects scales in
# skinny `[E, N, K/G]` layout but TritonMoeQuantInfo stores `[E, K/G, N]`.
# A scale transpose is needed at either the call site (per-forward overhead)
# or at load time (process_weights_after_loading reshuffle hook). Without
# that fix, the wiring is in place but the kernel will see wrong-layout scales.
# Live serving validation is deferred until the transpose lands.

diff --git a/python/sglang/srt/layers/moe/moe_runner/runner.py b/python/sglang/srt/layers/moe/moe_runner/runner.py
index d53f57cc1..22a202beb 100644
--- a/python/sglang/srt/layers/moe/moe_runner/runner.py
+++ b/python/sglang/srt/layers/moe/moe_runner/runner.py
@@ -48,6 +48,14 @@ class MoeRunner:
             from sglang.srt.layers.moe.moe_runner import aiter  # noqa: F401
 
             self.runner_core = None  # AITER only supports fused path
+        elif runner_backend.is_hybrid_w4a16():
+            # Side-effect import: registers the ("none", "hybrid_w4a16") fused func.
+            # Selected by MoeWNA16Method when SGLANG_MOE_HYBRID_W4A16=true on ROCm —
+            # routes through hybrid_w4a16_moe_apply (HIP wvSplitK decode + Triton
+            # prefill, switched by SGLANG_MOE_HYBRID_W4A16_MAX_BATCH).
+            from sglang.srt.layers.moe.moe_runner import hybrid_w4a16  # noqa: F401
+
+            self.runner_core = None  # HYBRID_W4A16 is fused-path only
         elif runner_backend.is_marlin():
             if lora_enabled:
                 from sglang.srt.lora.lora_moe_runner_marlin import MarlinLoraRunnerCore
