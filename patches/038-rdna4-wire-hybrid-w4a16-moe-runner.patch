index 2da526402..84cce3e2e 100644
--- a/python/sglang/srt/layers/quantization/moe_wna16.py
+++ b/python/sglang/srt/layers/quantization/moe_wna16.py
@@ -362,7 +362,23 @@ class MoeWNA16Method(FusedMoEMethodBase):
         self, layer: torch.nn.Module, moe_runner_config: MoeRunnerConfig
     ):
         self.moe_runner_config = moe_runner_config
-        self.runner = MoeRunner(MoeRunnerBackend.TRITON, moe_runner_config)
+        # 2026-05-12: prefer HYBRID_W4A16 backend on ROCm when the kernel is
+        # available + env-gated. Falls through to TRITON if either condition
+        # fails. SGLANG_MOE_HYBRID_W4A16 defaults True (see environ.py); set
