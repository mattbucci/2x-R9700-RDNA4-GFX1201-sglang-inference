# 038-rdna4-wire-hybrid-w4a16-moe-runner.patch
#
# Wire the wvSplitK INT4 MoE kernel (added by patch 032) into SGLang's
# MoeRunner so MoeWNA16Method can dispatch through it via the new
# MoeRunnerBackend.HYBRID_W4A16 backend, gated by SGLANG_MOE_HYBRID_W4A16.
#
# **2026-05-12 status: WIRING LANDED, KERNEL HANGS GPU (env defaults OFF).**
# Patch 038 puts the entire dispatch path in place: enum + dispatcher branch
# + new fused-func module + env-gated selection in MoeWNA16Method. Live
# launch with SGLANG_MOE_HYBRID_W4A16=true confirms the fused func IS
# invoked end-to-end and the wvSplitK kernel IS reached. But the kernel
# itself hangs the GPU on real Coder-30B-A3B weights:
#
#   HW Exception by GPU node-2 (Agent handle: ...) reason: GPU Hang
#   Fatal Python error: Aborted
#
# Matches memory project_moe_microbench_results.md: Triton baseline microbench
# also hung GPU on synthetic AWQ weights. Kernel-side debug needed before
# this can be enabled — likely related to qzeros handling (wvSplitK is
# symmetric-quant), expert-dim layout, or group_size=32 not in supported set.
#
# Default flipped to False (environ.py) so wiring stays inert in production.
# Set SGLANG_MOE_HYBRID_W4A16=true to opt in for kernel-debug benches.
#
# Components landed (~165 LOC):
#   - environ.py: SGLANG_MOE_HYBRID_W4A16 + MAX_BATCH (was missing from 032)
#   - utils.py: MoeRunnerBackend.HYBRID_W4A16 + is_hybrid_w4a16()
#   - moe_runner/runner.py: dispatch branch (side-effect import)
#   - moe_runner/hybrid_w4a16.py — NEW fused-func registration module
#   - moe_wna16.py: env-gated backend selection (default OFF)
#   - hybrid_w4a16_moe.py: .value → .get() fix (patch 032 used wrong API)

diff --git a/python/sglang/srt/environ.py b/python/sglang/srt/environ.py
index c7247261d..c2efddfa2 100644
--- a/python/sglang/srt/environ.py
+++ b/python/sglang/srt/environ.py
@@ -159,6 +159,22 @@ class ToolStrictLevel(IntEnum):
 class Envs:
     # fmt: off
 
+    # MoE hybrid W4A16 kernel (HIP wvSplitK INT4 GEMM for decode + Triton for
+    # prefill). Ported from mgehre-amd/vllm 0b992ff (2026-04-27).
+    # **2026-05-12 default flipped to False:** the wvSplitK kernel hangs the
+    # GPU on real Coder-30B-A3B weights at warmup ("HW Exception by GPU node-2
+    # reason: GPU Hang"). Wiring (patch 038) is in place but kernel-side debug
+    # is needed before this can be enabled in production. Set
+    # SGLANG_MOE_HYBRID_W4A16=true to opt in for kernel-debug benches; expect
+    # GPU hang on real MoE weights until the underlying kernel issue is fixed.
+    SGLANG_MOE_HYBRID_W4A16 = EnvBool(False)
+    # Threshold for HIP-vs-Triton dispatch in HybridW4A16MoEExperts: when
+    # num_tokens <= MAX_SKINNY_BATCH_SIZE, dispatch through the HIP kernel
+    # (decode-optimized); otherwise use Triton (prefill-optimized). Default
+    # matches mgehre's vLLM tuning of 5; raise to favor HIP on borderline
+    # batch sizes.
+    SGLANG_MOE_HYBRID_W4A16_MAX_BATCH = EnvInt(5)
+
     # Model & File Download
     SGLANG_USE_MODELSCOPE = EnvBool(False)
     SGLANG_SORT_WEIGHT_FILES = EnvBool(False)
