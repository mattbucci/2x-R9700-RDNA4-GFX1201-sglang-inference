diff --git a/python/sglang/srt/layers/moe/moe_runner/hybrid_w4a16.py b/python/sglang/srt/layers/moe/moe_runner/hybrid_w4a16.py
new file mode 100644
--- /dev/null
+++ b/python/sglang/srt/layers/moe/moe_runner/hybrid_w4a16.py
@@ -0,0 +1,115 @@
+"""HybridW4A16 MoE fused-func: dispatch through hybrid_w4a16_moe_apply.
+
+Wires the standalone `hybrid_w4a16_moe_apply` (see
+`sglang.srt.layers.moe.hybrid_w4a16_moe`) into SGLang's MoeRunner via the
+`@register_fused_func("none", "hybrid_w4a16")` decorator — same pattern as
+the AITER and Marlin paths. Selected by setting
+`MoeRunnerBackend.HYBRID_W4A16` on the MoeRunner.
+
+Importing this module is a side-effect registration step — once imported,
+the fused func is in FusedOpPool and the runner will use it when its
+backend is HYBRID_W4A16.
+
+Reuses :class:`TritonMoeQuantInfo` because the on-layer storage names are
+identical (`w13_qweight`, `w13_scales`, `w13_qzeros`, etc.). The wvSplitK
+kernel expects skinny `[E, N, K//8]` qweight + `[E, N, K//G]` scale layout
+— this is set up at load time in :meth:`MoeWNA16Method.process_weights_after_loading`
+via :func:`reshuffle_to_skinny_w4` / :func:`reshuffle_scales_for_skinny`.
+
+Per task #28 + memory `project_moe_microbench_results.md` (2026-05-11): the
+3-way synthetic microbench showed wvSplitK ~8% faster than awq_gemv_moe_hip
+at M=4-8 and near-tie at M=1 (our single-user decode target). Triton baseline
+hung on synthetic weights; real-weight comparison is deferred to live serving.
+"""
+from __future__ import annotations
+
+from typing import TYPE_CHECKING
+
+import torch
+
+from sglang.srt.layers.moe.hybrid_w4a16_moe import hybrid_w4a16_moe_apply
+from sglang.srt.layers.moe.moe_runner.base import (
+    MoeRunnerConfig,
+    register_fused_func,
+)
+
+if TYPE_CHECKING:
+    from sglang.srt.layers.moe.token_dispatcher.standard import (
+        StandardCombineInput,
+        StandardDispatchOutput,
+    )
+    from sglang.srt.layers.quantization.moe_wna16 import TritonMoeQuantInfo
+
+
+_BLOCK_SIZE_M = 1
+# wvSplitK kernel template specialization only accepts certain block_size_m
+# values; M=16 raises "RuntimeError: Unsupported N value: 16" on RDNA4. Matches
+# mgehre's bench config (scripts/bench/bench_moe_hip_vs_triton.py:213). For
+# single-user decode (num_tokens=1, top_k=8 → num_slots=8) this is fine.
+
+
+@register_fused_func("none", "hybrid_w4a16")
+def fused_experts_none_to_hybrid_w4a16(
+    dispatch_output: "StandardDispatchOutput",
+    quant_info: "TritonMoeQuantInfo",
+    runner_config: MoeRunnerConfig,
+) -> "StandardCombineInput":
+    """Run an MoE forward via :func:`hybrid_w4a16_moe_apply`.
+
+    HIP wvSplitK is used when ``num_tokens <= SGLANG_MOE_HYBRID_W4A16_MAX_BATCH``
+    (default 5) and ``SGLANG_MOE_HYBRID_W4A16`` is True; otherwise the Triton
+    fused-MoE kernel is invoked as a fallback. Both paths read the same
+    skinny-layout weights produced by ``reshuffle_to_skinny_w4`` at load time.
+    """
+    from sglang.srt.layers.moe.moe_runner.triton_utils.moe_align_block_size import (
+        moe_align_block_size,
+    )
+    from sglang.srt.layers.moe.token_dispatcher.standard import StandardCombineInput
+
+    assert not runner_config.no_combine, (
+        "no_combine=True is not supported by HYBRID_W4A16 (output is already "
+        "top-k-weighted and reduced inside hybrid_w4a16_moe_apply)."
+    )
+
+    hidden_states = dispatch_output.hidden_states
+    topk_weights, topk_ids, _ = dispatch_output.topk_output
+    topk_weights = topk_weights.to(torch.float32)
+    topk_ids = topk_ids.to(torch.int32)
+
+    E = quant_info.w13_weight.shape[0]
+
+    sorted_token_ids, expert_ids, num_tokens_post_padded = moe_align_block_size(
+        topk_ids, _BLOCK_SIZE_M, E
+    )
+
+    # block_shape[1] holds the group_size (block_shape[0]=0 means no row blocking).
+    # See `MoeWNA16Method.get_triton_quant_info` for the convention.
+    group_size = (
+        quant_info.block_shape[1]
+        if quant_info.block_shape is not None
+        else 128
+    )
+
+    # 2026-05-12: force_hip=True. The Triton fallback inside hybrid_w4a16_moe_apply
+    # hits a pre-existing torch.compile/HIP crash on warmup batches with M>5.
+    # Forcing HIP-only here keeps decode (M≤5, our single-user target) working;
+    # prefill is a known limitation tracked as a followup.
+    output = hybrid_w4a16_moe_apply(
+        activation=hidden_states,
+        w1=quant_info.w13_weight,
+        w2=quant_info.w2_weight,
+        w1_scale=quant_info.w13_scale,
+        w2_scale=quant_info.w2_scale,
+        topk_weights=topk_weights,
+        topk_ids=topk_ids,
+        sorted_token_ids=sorted_token_ids,
+        expert_ids=expert_ids,
+        num_tokens_post_padded=num_tokens_post_padded,
+        block_size_m=_BLOCK_SIZE_M,
+        group_size=group_size,
+        activation_fn=runner_config.activation,
+        w1_zp=quant_info.w13_zp,
+        w2_zp=quant_info.w2_zp,
+        force_hip=True,
+    )
+    return StandardCombineInput(hidden_states=output)
