@@ -79,6 +79,10 @@ class MoeRunnerBackend(Enum):
     CUTLASS = "cutlass"
     MARLIN = "marlin"
     AITER = "aiter"
+    # 2026-05-12: RDNA4 wvSplitK INT4 MoE kernel (mgehre-amd/vllm port via patch 032).
+    # Fused-func dispatch (M<=N: wvSplitK HIP; M>N: Triton fallback), gated by
+    # SGLANG_MOE_HYBRID_W4A16. See moe_runner/hybrid_w4a16.py.
+    HYBRID_W4A16 = "hybrid_w4a16"
 
     def is_auto(self):
