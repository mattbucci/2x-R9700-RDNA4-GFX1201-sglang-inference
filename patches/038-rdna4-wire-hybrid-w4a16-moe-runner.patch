+        backend = MoeRunnerBackend.TRITON
+        try:
+            from sglang.srt.environ import envs
+            from sglang.srt.utils import is_hip
+            if is_hip() and envs.SGLANG_MOE_HYBRID_W4A16.get():
+                try:
+                    import skinny_gemms_int4_ext  # noqa: F401  — must be built
+                    backend = MoeRunnerBackend.HYBRID_W4A16
+                except ImportError:
