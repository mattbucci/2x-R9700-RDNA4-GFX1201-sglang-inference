+# --- Torch-based fallbacks for missing ops ---
+# When common_ops is partially available (e.g. ROCm/HIP build with subset of ops),
+# the submodule .py wrappers import fine but call torch.ops.sgl_kernel.* at runtime.
+# Check which ops are actually registered and provide torch fallbacks for any missing ones.
+def _has_op(name):
+    """Check if a torch.ops.sgl_kernel op is registered."""
+    try:
+        getattr(torch.ops.sgl_kernel, name)
+        return True
+    except (AttributeError, RuntimeError):
+        return False
+
+import torch.nn.functional as _F
+
+# Define all torch fallbacks, then selectively install only for missing ops.
+# This way, native HIP ops (silu_and_mul, gelu_and_mul, moe_align_block_size,
+# topk_softmax) are used when available, and torch fallbacks fill the gaps.
+
+def _fb_silu_and_mul(input: torch.Tensor, out: torch.Tensor = None) -> torch.Tensor:
+    d = input.shape[-1] // 2
+    result = _F.silu(input[..., :d]) * input[..., d:]
+    if out is not None:
+        out.copy_(result)
+        return out
+    return result
+
+def _fb_gelu_and_mul(input: torch.Tensor, out: torch.Tensor = None) -> torch.Tensor:
+    d = input.shape[-1] // 2
+    result = _F.gelu(input[..., :d]) * input[..., d:]
+    if out is not None:
+        out.copy_(result)
+        return out
+    return result
+
+def _fb_gelu_tanh_and_mul(input: torch.Tensor, out: torch.Tensor = None) -> torch.Tensor:
+    d = input.shape[-1] // 2
+    result = _F.gelu(input[..., :d], approximate="tanh") * input[..., d:]
+    if out is not None:
+        out.copy_(result)
+        return out
+    return result
+
+def _fb_gelu_quick(input: torch.Tensor, out: torch.Tensor = None) -> torch.Tensor:
+    result = input * torch.sigmoid(1.702 * input)
+    if out is not None:
+        out.copy_(result)
+        return out
+    return result
+
+def _fb_rmsnorm(input: torch.Tensor, weight: torch.Tensor, eps: float = 1e-6) -> torch.Tensor:
+    variance = input.to(torch.float32).pow(2).mean(-1, keepdim=True)
+    input_norm = input * torch.rsqrt(variance + eps)
+    return (weight * input_norm).to(input.dtype)
 
+def _fb_fused_add_rmsnorm(input: torch.Tensor, residual: torch.Tensor,
+                      weight: torch.Tensor, eps: float = 1e-6):
+    input += residual
+    residual[:] = input
+    variance = input.to(torch.float32).pow(2).mean(-1, keepdim=True)
+    input_norm = input * torch.rsqrt(variance + eps)
+    return (weight * input_norm).to(input.dtype)
 
+def _fb_rotary_embedding(positions: torch.Tensor, query: torch.Tensor,
+                     key: torch.Tensor, head_size: int,
+                     cos_sin_cache: torch.Tensor, is_neox: bool = True):
+    """Torch fallback for rotary embedding (in-place)."""
+    cos_sin_cache = cos_sin_cache.to(query.device, dtype=query.dtype)
+    rot_dim = cos_sin_cache.shape[1]
+    half_rot = rot_dim // 2
+    cos = cos_sin_cache[positions, :half_rot]
+    sin = cos_sin_cache[positions, half_rot:]
+
+    def _apply_rotary(t, cos, sin, head_size, is_neox):
+        batch = t.shape[0]
+        t_view = t.view(batch, -1, head_size)
+        nheads = t_view.shape[1]
+        cos_e = cos.unsqueeze(1).expand(batch, nheads, half_rot)
+        sin_e = sin.unsqueeze(1).expand(batch, nheads, half_rot)
+        rot = t_view[..., :half_rot]
+        if is_neox:
+            x1 = rot[..., :half_rot // 2]
+            x2 = rot[..., half_rot // 2:]
+            rot_out = torch.cat([x1 * cos_e[..., :half_rot//2] - x2 * sin_e[..., :half_rot//2],
+                                 x2 * cos_e[..., half_rot//2:] + x1 * sin_e[..., half_rot//2:]], dim=-1)
+        else:
+            rot_even = rot[..., 0::2]
+            rot_odd = rot[..., 1::2]
+            rot_out = torch.stack([
+                rot_even * cos_e[..., 0::2] - rot_odd * sin_e[..., 0::2],
+                rot_odd * cos_e[..., 1::2] + rot_even * sin_e[..., 1::2],
+            ], dim=-1).flatten(-2)
+        t_view[..., :half_rot] = rot_out
+
+    _apply_rotary(query, cos, sin, head_size, is_neox)
+    _apply_rotary(key, cos, sin, head_size, is_neox)
+
+def _fb_topk_softmax(topk_weights: torch.Tensor, topk_ids: torch.Tensor,
+                 gating_output: torch.Tensor, renormalize: bool = False,
+                 moe_softcapping: float = 0.0, correction_bias=None) -> None:
+    if moe_softcapping > 0:
+        gating_output = gating_output / moe_softcapping
+        gating_output = gating_output.tanh()
+        gating_output = gating_output * moe_softcapping
+    scores = _F.softmax(gating_output, dim=-1)
+    if correction_bias is not None:
+        scores = scores + correction_bias.to(scores.dtype)
+    topk = topk_weights.shape[1]
+    tw, ti = torch.topk(scores, topk, dim=-1)
+    topk_weights.copy_(tw)
+    topk_ids.copy_(ti)
+    if renormalize:
+        s = topk_weights.sum(dim=-1, keepdim=True).clamp(min=1e-20)
+        topk_weights.div_(s)
+
+def _fb_topk_sigmoid(topk_weights: torch.Tensor, topk_ids: torch.Tensor,
+                 gating_output: torch.Tensor, renormalize: bool = False,
+                 correction_bias=None) -> None:
+    scores = torch.sigmoid(gating_output)
+    if correction_bias is not None:
+        scores = scores + correction_bias.to(scores.dtype)
+    topk = topk_weights.shape[1]
+    tw, ti = torch.topk(scores, topk, dim=-1)
+    topk_weights.copy_(tw)
+    topk_ids.copy_(ti)
+    if renormalize:
+        s = topk_weights.sum(dim=-1, keepdim=True).clamp(min=1e-20)
+        topk_weights.div_(s)
+
+def _fb_moe_align_block_size(topk_ids, num_experts_plus_one, block_size,
+                         sorted_ids, expert_ids, num_tokens_post_pad,
+                         cumsum_buffer, expert_filtering=True):
+    flat_ids = topk_ids.flatten()
+    num_tokens_total = flat_ids.numel()
+    num_experts = num_experts_plus_one - 1
+    expert_counts = torch.zeros(num_experts_plus_one, dtype=torch.int32,
+                                device=topk_ids.device)
+    for e in range(num_experts):
+        expert_counts[e + 1] = (flat_ids == e).sum()
+    expert_counts[0] = (flat_ids == -1).sum()
+    padded_counts = ((expert_counts + block_size - 1) // block_size) * block_size
+    offsets = torch.zeros_like(padded_counts)
+    torch.cumsum(padded_counts, dim=0, out=offsets)
+    total_padded = offsets[-1].item()
+    sorted_ids.fill_(num_tokens_total)
+    write_pos = torch.zeros(num_experts_plus_one, dtype=torch.int32,
+                            device=topk_ids.device)
+    write_pos[1:] = offsets[:-1]
+    for idx in range(num_tokens_total):
+        e = flat_ids[idx].item()
+        slot = 0 if e == -1 else e + 1
+        pos = write_pos[slot].item()
+        if pos < sorted_ids.shape[0]:
+            sorted_ids[pos] = idx
+        write_pos[slot] += 1
+    block_idx = 0
+    for e in range(num_experts_plus_one):
+        n_blocks = padded_counts[e].item() // block_size
+        expert_val = e - 1
+        for _ in range(n_blocks):
+            if block_idx < expert_ids.shape[0]:
