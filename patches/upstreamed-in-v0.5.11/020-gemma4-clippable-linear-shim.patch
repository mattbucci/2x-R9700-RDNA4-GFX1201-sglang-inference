+"""Clippable parallel linear shims for Gemma 4 multimodal modules.
+
+The upstream `gemma4_audio.py` / `gemma4_vision.py` / `gemma4_mm.py` loaders
+import `Clippable*ParallelLinear` classes that haven't landed in SGLang
+v0.5.10 yet. Without these imports those loaders fail and SGLang silently
+falls back to `Gemma4ForCausalLM` (text-only), which makes Gemma 4 26B emit
+`<pad>` (no expert routing) and 21B-REAP discard image tokens
+("i cannot see the image").
+
+These shims alias the existing Parallel Linear classes 1:1. The constructor
+signatures match in `models/gemma4_*.py` (no clip-bound kwargs are passed at
+construction) so a drop-in subclass without an actual output-clip op
+restores the multimodal load path. The clip bounds are a fine-tune-time
+training stability mechanism in the Gemma 4 paper; their absence at
+inference may slightly drift activations near the dynamic range edges but
+beats the current "vision tower never runs" failure mode.
+
+If the multimodal output looks degraded after this lands, follow up by
+porting the actual `ClippableLinear` op from upstream SGLang main.
+"""
+
+from sglang.srt.layers.linear import (
+    ColumnParallelLinear,
+    MergedColumnParallelLinear,
+    QKVParallelLinear,
+    RowParallelLinear,
+)
+
+ClippableColumnParallelLinear = ColumnParallelLinear
+ClippableRowParallelLinear = RowParallelLinear
+ClippableQKVParallelLinear = QKVParallelLinear
+ClippableGateUpParallelLinear = MergedColumnParallelLinear
+ClippableGLUParallelLinear = MergedColumnParallelLinear
