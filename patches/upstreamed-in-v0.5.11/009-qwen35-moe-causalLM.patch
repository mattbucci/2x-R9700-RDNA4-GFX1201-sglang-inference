+def _should_replicate_deltanet_for_tp(
+    quant_config: Optional[QuantizationConfig],
+) -> bool:
+    """Whether to replicate DeltaNet+MLP layers across TP ranks.
+
+    DeltaNet projections are always replicated (tp_size=1) to avoid FP16
+    rounding errors accumulating in the recurrent state.  When this returns
+    True, MLPs in DeltaNet layers are *also* replicated, which saves one
+    all-reduce but doubles MoE expert VRAM.  For quantized models (AWQ,
+    FP8, etc.) the MoE duplication pushes memory over the limit on
+    consumer GPUs, so we only replicate projections (return False).
+    """
+    if quant_config is None:
+        return True
+    name = quant_config.get_name()
+    return name not in ("fp8", "mxfp8", "w8a8_fp8")
+
