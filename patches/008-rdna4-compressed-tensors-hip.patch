+    @staticmethod
+    def _hip_dequant_matmul(
+        x: torch.Tensor,
+        w_packed: torch.Tensor,
+        w_scale: torch.Tensor,
+        group_size: int,
+        symmetric: bool,
+        w_zp: Optional[torch.Tensor] = None,
+        bias: Optional[torch.Tensor] = None,
+    ) -> torch.Tensor:
+        """Dequantize INT4 packed weights and matmul on HIP/ROCm.
+
+        Weights are in compressed-tensors format:
+          w_packed: [out, in//8] int32, sequential 4-bit packing
+          w_scale:  [out, in//group_size] float
+        """
+        pack_factor = 8  # 8x 4-bit values per int32
+        out_features = w_packed.shape[0]
+        in_features = w_packed.shape[1] * pack_factor
+
+        # Unpack int32 → 4-bit values: extract sequentially
+        unpacked = []
+        for i in range(pack_factor):
+            unpacked.append((w_packed >> (i * 4)) & 0xF)
+        # [out, in] as int8
+        w_int = torch.stack(unpacked, dim=-1).reshape(out_features, in_features)
+
+        # Dequantize: (w_int - zero_point) * scale
+        # scale is [out, in//G] → expand to [out, in]
+        scale_expanded = w_scale.to(torch.float32).repeat_interleave(group_size, dim=1)
+        if scale_expanded.shape[1] > in_features:
+            scale_expanded = scale_expanded[:, :in_features]
+
+        if symmetric:
+            w_float = (w_int.to(torch.float32) - 8.0) * scale_expanded
+        else:
+            # Asymmetric: unpack zero points similarly
+            if w_zp is not None:
+                zp_unpacked = []
+                for i in range(pack_factor):
+                    zp_unpacked.append((w_zp >> (i * 4)) & 0xF)
+                zp_int = torch.stack(zp_unpacked, dim=-1).reshape(
+                    w_zp.shape[0], -1)
+                zp_expanded = zp_int.to(torch.float32).repeat_interleave(
+                    group_size, dim=1)
+                if zp_expanded.shape[1] > in_features:
+                    zp_expanded = zp_expanded[:, :in_features]
+            else:
+                zp_expanded = 8.0
+            w_float = (w_int.to(torch.float32) - zp_expanded) * scale_expanded
