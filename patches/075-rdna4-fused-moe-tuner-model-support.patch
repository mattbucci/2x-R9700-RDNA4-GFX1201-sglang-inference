+_TOPK_IDS_FILENAME_RE = re.compile(
+    r"topk_ids_layer(?P<layer>\d+)_idx(?P<capture>\d+)\.pt"
+)
+
+
+def discover_topk_ids_files(topk_ids_dir: str) -> Tuple[str, ...]:
+    """Return captured router outputs in capture-major, layer-minor order.
+
+    Layer counts and dense-layer prefixes vary across model architectures.  The
+    capture filenames already contain both coordinates, so derive the sequence
+    from the files instead of embedding one model's layer layout in the tuner.
+    """
+    directory = Path(topk_ids_dir).expanduser()
+    captures = []
+    for path in directory.iterdir():
+        match = _TOPK_IDS_FILENAME_RE.fullmatch(path.name)
+        if match is not None and path.is_file():
+            captures.append(
+                (int(match["capture"]), int(match["layer"]), str(path))
+            )
+
+    if not captures:
+        raise FileNotFoundError(
+            f"No top-k captures matching topk_ids_layer<layer>_idx<capture>.pt "
+            f"were found in {directory}"
+        )
+
+    captures.sort(key=lambda capture: (capture[0], capture[1]))
+    return tuple(capture[2] for capture in captures)
+
+
+def get_topk_ids_file(topk_ids_dir: str, index: int) -> str:
+    """Select a capture, cycling when fewer than the benchmark iteration count."""
+    if index < 0:
+        raise ValueError(f"top-k capture index must be non-negative, got {index}")
+    captures = discover_topk_ids_files(topk_ids_dir)
+    return captures[index % len(captures)]
+
