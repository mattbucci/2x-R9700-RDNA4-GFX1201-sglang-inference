+import importlib.util
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+from types import ModuleType, SimpleNamespace
+from unittest import mock
+
+import torch
+
+
+def _module(name, *, package=False, **attributes):
+    module = ModuleType(name)
+    if package:
+        module.__path__ = []
+    module.__dict__.update(attributes)
+    return module
+
+
+def _load_common_utils():
+    package_names = [
+        "sglang",
+        "sglang.srt",
+        "sglang.srt.layers",
+        "sglang.srt.layers.moe",
+        "sglang.srt.layers.moe.moe_runner",
+        "sglang.srt.layers.moe.moe_runner.triton_utils",
+        "sglang.srt.utils",
+    ]
+    stubs = {name: _module(name, package=True) for name in package_names}
+    stubs.update(
+        {
+            "sglang.srt.layers.moe.moe_runner.triton_utils.fused_moe_triton_config": _module(
+                "sglang.srt.layers.moe.moe_runner.triton_utils.fused_moe_triton_config",
+                get_config_dtype_str=lambda *args, **kwargs: "",
+                get_config_file_name=lambda *args, **kwargs: "",
+            ),
+            "sglang.srt.utils.hf_transformers_utils": _module(
+                "sglang.srt.utils.hf_transformers_utils",
+                get_config=lambda *args, **kwargs: None,
+            ),
+        }
+    )
+    stubs["sglang.srt.utils"].is_gfx95_supported = lambda: False
+    stubs["sglang.srt.utils"].is_hip = lambda: False
+
+    common_utils_path = (
+        Path(__file__).parents[3]
+        / "benchmark/kernels/fused_moe_triton/common_utils.py"
+    )
+    spec = importlib.util.spec_from_file_location(
+        "_fused_moe_tuner_common_utils", common_utils_path
+    )
+    module = importlib.util.module_from_spec(spec)
+    with mock.patch.dict(sys.modules, stubs):
+        spec.loader.exec_module(module)
+    return module
+
+
+common_utils = _load_common_utils()
+
+
+def _config(architecture, *, weights, **kwargs):
+    return SimpleNamespace(
+        architectures=[architecture],
+        hidden_size=2048,
+        torch_dtype=torch.bfloat16,
+        quantization_config={"config_groups": {"group_0": {"weights": weights}}},
+        **kwargs,
+    )
+
+
+class TestFusedMoeTunerCommonUtils(unittest.TestCase):
+    def test_discovers_north_routed_layers_without_architecture_constants(self):
+        with tempfile.TemporaryDirectory() as tmpdir:
+            directory = Path(tmpdir)
+            # North has 49 transformer layers with one dense prefix layer.
+            for layer in range(1, 49):
+                (directory / f"topk_ids_layer{layer}_idx0.pt").touch()
+
+            captures = common_utils.discover_topk_ids_files(tmpdir)
+
+        self.assertEqual(len(captures), 48)
+        self.assertEqual(Path(captures[0]).name, "topk_ids_layer1_idx0.pt")
+        self.assertEqual(Path(captures[-1]).name, "topk_ids_layer48_idx0.pt")
+
+    def test_discovers_laguna_captures_in_numeric_capture_then_layer_order(self):
+        with tempfile.TemporaryDirectory() as tmpdir:
+            directory = Path(tmpdir)
+            # Laguna has 40 transformer layers with one dense prefix layer.
+            for capture in range(2):
+                for layer in range(1, 40):
+                    (directory / f"topk_ids_layer{layer}_idx{capture}.pt").touch()
+            (directory / "topk_ids_layer1_idx0.pt.backup").touch()
+            (directory / "notes.txt").touch()
+
+            captures = common_utils.discover_topk_ids_files(tmpdir)
+
+        self.assertEqual(len(captures), 78)
+        self.assertEqual(Path(captures[9]).name, "topk_ids_layer10_idx0.pt")
+        self.assertEqual(Path(captures[38]).name, "topk_ids_layer39_idx0.pt")
+        self.assertEqual(Path(captures[39]).name, "topk_ids_layer1_idx1.pt")
+
+    def test_topk_capture_selection_cycles_available_files(self):
+        with tempfile.TemporaryDirectory() as tmpdir:
+            directory = Path(tmpdir)
+            for layer in (3, 7):
+                (directory / f"topk_ids_layer{layer}_idx0.pt").touch()
+
+            selected = [
+                Path(common_utils.get_topk_ids_file(tmpdir, i)).name
+                for i in range(3)
+            ]
+
+        self.assertEqual(
+            selected,
+            [
+                "topk_ids_layer3_idx0.pt",
+                "topk_ids_layer7_idx0.pt",
+                "topk_ids_layer3_idx0.pt",
+            ],
+        )
+
+    def test_topk_capture_discovery_rejects_empty_directory(self):
+        with tempfile.TemporaryDirectory() as tmpdir:
+            with self.assertRaisesRegex(FileNotFoundError, "No top-k captures"):
+                common_utils.discover_topk_ids_files(tmpdir)
+
+    def test_laguna_compressed_tensors_block_shape_and_moe_shape(self):
+        config = _config(
+            "LagunaForCausalLM",
+            weights={"block_structure": [128, 128], "group_size": None},
+            num_experts=256,
+            num_experts_per_tok=8,
+            moe_intermediate_size=512,
+        )
+        with mock.patch.object(common_utils, "get_config", return_value=config):
+            model_config = common_utils.get_model_config("laguna", tp_size=2)
+
+        self.assertEqual(
+            model_config,
+            {
+                "num_experts": 256,
+                "topk": 8,
+                "hidden_size": 2048,
+                "shard_intermediate_size": 512,
+                "dtype": torch.bfloat16,
+                "block_shape": [128, 128],
+                "architecture": "LagunaForCausalLM",
+            },
+        )
+
+    def test_north_channel_quantization_has_no_block_shape(self):
+        config = _config(
+            "Cohere2MoeForCausalLM",
+            weights={"block_structure": None, "group_size": None},
+            num_experts=128,
+            num_experts_per_tok=8,
+            intermediate_size=768,
+        )
+        with mock.patch.object(common_utils, "get_config", return_value=config):
+            model_config = common_utils.get_model_config("north", tp_size=2)
+
+        self.assertEqual(model_config["num_experts"], 128)
+        self.assertEqual(model_config["topk"], 8)
+        self.assertEqual(model_config["shard_intermediate_size"], 768)
+        self.assertIsNone(model_config["block_shape"])
+
+    def test_compressed_tensors_group_quantization_uses_group_size(self):
+        config = _config(
+            "Cohere2MoeForCausalLM",
+            weights={"block_structure": None, "group_size": 64},
+            num_experts=128,
+            num_experts_per_tok=8,
+            intermediate_size=768,
+        )
+        with mock.patch.object(common_utils, "get_config", return_value=config):
+            model_config = common_utils.get_model_config("grouped", tp_size=2)
+
+        self.assertEqual(model_config["block_shape"], [0, 64])
+
+    def test_rocm_search_grid_includes_rdna4_decode_candidates(self):
+        configs = common_utils.get_rocm_configs_compute_bound()
+
+        self.assertEqual({config["num_stages"] for config in configs}, {0, 2})
+        self.assertEqual(
+            {config["BLOCK_SIZE_M"] for config in configs}, {16, 32, 64, 128, 256}
+        )
+
+    def test_fp8_scale_shapes_match_channel_quantized_weights(self):
+        self.assertEqual(
+            common_utils.get_fp8_scale_shapes(128, 768, 2048, True),
+            ((128, 768), (128, 2048)),
+        )
+        self.assertEqual(
+            common_utils.get_fp8_scale_shapes(64, 1536, 2048, True),
+            ((64, 1536), (64, 2048)),
+        )
+        self.assertEqual(
+            common_utils.get_fp8_scale_shapes(128, 768, 2048, False),
+            ((128,), (128,)),
+        )
+
+    def test_per_channel_config_names_distinguish_up_and_down_kernels(self):
+        up_name = (
+            "E=128,N=384,device_name=AMD_Radeon_AI_PRO_R9700,"
+            "dtype=fp8_w8a8,per_channel_quant=True.json"
+        )
+        down_name = up_name.removesuffix(".json") + "_down.json"
+
+        with (
+            mock.patch.object(
+                common_utils, "get_config_dtype_str", return_value="fp8_w8a8"
+            ),
+            mock.patch.object(
+                common_utils,
+                "get_config_file_name",
+                side_effect=[up_name, down_name],
+            ) as get_config_file_name,
+        ):
+            common_args = (
+                128,
+                768,
+                2048,
+                8,
+                torch.bfloat16,
+                True,
+                False,
+                False,
+                False,
+                True,
+                None,
+            )
+            self.assertEqual(common_utils.get_config_filename(*common_args), up_name)
+            self.assertEqual(
+                common_utils.get_config_filename(*common_args, down_moe=True), down_name
+            )
+
+        get_config_file_name.assert_has_calls(
+            [
+                mock.call(
+                    128,
+                    384,
+                    "fp8_w8a8",
+                    None,
+                    True,
+                    down_moe=False,
+                ),
+                mock.call(
+                    128,
+                    384,
+                    "fp8_w8a8",
+                    None,
+                    True,
+                    down_moe=True,
+                ),
+            ]
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()

