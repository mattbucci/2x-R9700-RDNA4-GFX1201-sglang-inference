+def _create_kv_indices(req_to_token, req_pool_indices, page_kernel_lens,
+                       kv_indptr, kv_start_idx, kv_indices):
+    """PyTorch replacement for create_flashinfer_kv_indices_triton.
+    The Triton kernel crashes with HSA exception on RDNA4 (gfx1201)."""
+    bs = req_pool_indices.shape[0]
+    for i in range(bs):
+        rpi = req_pool_indices[i].item()
+        kv_len = page_kernel_lens[i].item()
+        offset = kv_indptr[i].item()
+        start = kv_start_idx[i].item() if kv_start_idx is not None else 0
+        if kv_len > 0:
+            kv_indices[offset:offset + kv_len] = req_to_token[rpi, start:start + kv_len]
+
