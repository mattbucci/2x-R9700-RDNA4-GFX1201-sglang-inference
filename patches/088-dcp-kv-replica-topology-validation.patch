+class TestMhaDcpKvHeadTopology(unittest.TestCase):
+    def test_accepts_aligned_replica_blocks(self):
+        for attention_tp_size, total_num_kv_heads, dcp_size in [
+            (8, 4, 2),
+            (8, 2, 4),
+            (2, 1, 2),
+        ]:
+            validate_mha_dcp_kv_head_topology(
+                attention_tp_size=attention_tp_size,
+                total_num_kv_heads=total_num_kv_heads,
+                dcp_size=dcp_size,
+            )
+
+    def test_dcp_size_one_needs_no_kv_replication(self):
+        validate_mha_dcp_kv_head_topology(
+            attention_tp_size=2,
+            total_num_kv_heads=4,
+            dcp_size=1,
+        )
+
+    def test_rejects_partitioned_kv_heads(self):
+        with self.assertRaisesRegex(
+            ValueError,
+            r"num_kv_head_replicas % dcp_size == 0.*"
+            r"num_kv_head_replicas=1, dcp_size=2",
+        ):
+            validate_mha_dcp_kv_head_topology(
+                attention_tp_size=2,
+                total_num_kv_heads=4,
+                dcp_size=2,
+            )
+
+    def test_rejects_dcp_group_crossing_replica_boundary(self):
+        # Replicas >= DCP is insufficient: with three replicas per KV head,
+        # adjacent DCP2 group [2, 3] crosses from KV head 0 to KV head 1.
+        with self.assertRaisesRegex(
+            ValueError, r"num_kv_head_replicas % dcp_size == 0"
+        ):
+            validate_mha_dcp_kv_head_topology(
+                attention_tp_size=6,
+                total_num_kv_heads=2,
+                dcp_size=2,
+            )
+
+
 if __name__ == "__main__":
     unittest.main()
