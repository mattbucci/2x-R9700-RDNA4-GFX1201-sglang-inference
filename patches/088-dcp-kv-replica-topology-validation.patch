+def validate_mha_dcp_kv_head_topology(
+    *, attention_tp_size: int, total_num_kv_heads: int, dcp_size: int
+) -> None:
+    """Reject MHA DCP groups that cross TP KV-head replica blocks.
+
+    The current MHA DCP path all-gathers query heads across each DCP group but
+    keeps K/V local. Therefore, every rank in a DCP group must load the same
+    replicated KV-head shard. QKVParallelLinear lays out each replica block on
+    consecutive TP ranks, as does the DCP group construction.
+    """
+    if dcp_size <= 1:
+        return
+
+    num_kv_head_replicas = 1
+    if (
+        attention_tp_size >= total_num_kv_heads
+        and attention_tp_size % total_num_kv_heads == 0
+    ):
+        num_kv_head_replicas = attention_tp_size // total_num_kv_heads
+
+    if num_kv_head_replicas % dcp_size != 0:
+        raise ValueError(
+            "Decode context parallel MHA requires every DCP group to stay "
+            "within one replicated KV-head block. The current MHA DCP topology "
+            "requires num_kv_head_replicas % dcp_size == 0, but got "
+            f"attention_tp_size={attention_tp_size}, "
+            f"total_num_kv_heads={total_num_kv_heads}, "
+            f"num_kv_head_replicas={num_kv_head_replicas}, "
+            f"dcp_size={dcp_size}. Choose a smaller DCP size or a TP/model "
+            "topology with enough KV-head replication."
+        )
+
+
